# Environment Variables for ADS Windows Auth API
# Copy this file to .env and set your actual values

# Active Directory Service Account Password
ADS_AD_SERVICE_PASSWORD=your_actual_ad_password_here

# JWT Signing Key (minimum 32 characters)
ADS_JWT_KEY=your_super_secure_jwt_key_minimum_32_chars_long

# Database Connection String (optional - overrides appsettings.json)
ADS_CONNECTION_STRING=Server=localhost;Database=ADS_WindowsAuth;Integrated Security=true;TrustServerCertificate=true;

# Azure Key Vault URI (optional - for production)
AZURE_KEY_VAULT_URI=https://your-keyvault.vault.azure.net/
