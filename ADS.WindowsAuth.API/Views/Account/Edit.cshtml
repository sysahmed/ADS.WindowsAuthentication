@model EditUserViewModel
@{
    ViewData["Title"] = "Редакция на потребител";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="glass-card p-4">
                <div class="d-flex align-items-center mb-4">
                    <span style="font-size:2rem; margin-right:1rem;">✏️</span>
                    <div>
                        <h4 class="mb-0">Редакция: @Model.UserName</h4>
                        <small class="text-muted">Администратор – смяна на роля, имейл, парола</small>
                    </div>
                    <a href="/Account/Users" class="btn btn-outline-secondary btn-sm ms-auto">← Назад</a>
                </div>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }

                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="UserName" class="form-label">Потребителско Име</label>
                            <input asp-for="UserName" class="form-control" readonly disabled />
                            <small class="text-muted">Не може да се променя</small>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label">Имейл</label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="user@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DisplayName" class="form-label">Пълно Име</label>
                            <input asp-for="DisplayName" class="form-control" placeholder="Иван Петров" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Role" class="form-label">Роля</label>
                            <select asp-for="Role" class="form-select" asp-items="@(new SelectList(ViewBag.Roles as IEnumerable<string> ?? new[] { "User", "Monitor", "Admin" }))">
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Notes" class="form-label">Бележки</label>
                            <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Опционални бележки"></textarea>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch mt-3">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="IsActive" class="form-check-label">Активен акаунт</label>
                            </div>
                        </div>
                    </div>

                    <div asp-validation-summary="All" class="alert alert-danger mt-3" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">💾 Запази</button>
                        <a href="/Account/Users" class="btn btn-outline-secondary">Отказ</a>
                    </div>
                </form>

                <hr class="my-4" />
                <h5 class="mb-3">🔐 Смяна на парола (Admin)</h5>
                <form asp-action="ResetPassword" method="post" id="resetPwForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="row g-2 align-items-end">
                        <div class="col-md-6">
                            <label class="form-label">Нова парола</label>
                            <input type="password" name="newPassword" class="form-control" minlength="8" placeholder="Мин. 8 символа" required />
                        </div>
                        <div class="col-md-6">
                            <button type="submit" class="btn btn-warning" onclick="return confirm('Сигурни ли сте, че искате да смените паролата на този потребител?')">
                                🔑 Смени парола
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
