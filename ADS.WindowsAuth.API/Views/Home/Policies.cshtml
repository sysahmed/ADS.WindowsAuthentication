@{
    Layout = null;
    ViewData["Title"] = "Управление на политики";
    var policies = ViewBag.Policies as List<ADS.WindowsAuth.Core.Models.Policy> ?? new List<ADS.WindowsAuth.Core.Models.Policy>();
}
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ADS Windows Authentication</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: #f5f5f5;
            padding-top: 20px;
        }
        .navbar {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            margin-bottom: 20px;
        }
        .navbar-brand {
            color: white !important;
            font-weight: 700;
        }
        .nav-link {
            color: rgba(255,255,255,0.8) !important;
        }
        .nav-link:hover {
            color: white !important;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="/">🔐 ADS Windows Auth</a>
            <div class="navbar-nav">
                <a class="nav-link" href="/">🏠 Начало</a>
                <a class="nav-link" href="/policies">🔒 Политики</a>
                <a class="nav-link" href="/monitor-settings">⚙️ Настройки</a>
                <a class="nav-link" href="/logs">📊 Логове</a>
            </div>
        </div>
    </nav>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h2 class="mb-4">🔒 Управление на политики</h2>
            <button type="button" class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#createPolicyModal">
                ➕ Създай нова политика
            </button>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>Списък с политики</h5>
                </div>
                <div class="card-body">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Име</th>
                                <th>Статус</th>
                                <th>Блокирани сайтове</th>
                                <th>Блокирани приложения</th>
                                <th>Машини</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var policy in policies)
                            {
                                <tr>
                                    <td>@policy.Id</td>
                                    <td>@policy.Name</td>
                                    <td>
                                        @if (policy.IsActive)
                                        {
                                            <span class="badge bg-success">Активна</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Неактивна</span>
                                        }
                                    </td>
                                    <td>@policy.BlockedWebsites.Count</td>
                                    <td>@policy.BlockedApplications.Count</td>
                                    <td>@(policy.TargetMachines.Count > 0 ? string.Join(", ", policy.TargetMachines) : "Всички")</td>
                                    <td>
                                        <button class="btn btn-sm btn-primary" onclick="editPolicy(@policy.Id)">✏️ Редактирай</button>
                                        <button class="btn btn-sm btn-danger" onclick="deletePolicy(@policy.Id)">🗑️ Изтрий</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal за създаване/редактиране на политика -->
<div class="modal fade" id="createPolicyModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="policyModalTitle">Създай нова политика</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="policyForm">
                    <input type="hidden" id="policyId" name="Id" value="0">
                    <div class="mb-3">
                        <label for="policyName" class="form-label">Име на политиката:</label>
                        <input type="text" class="form-control" id="policyName" name="Name" required>
                    </div>
                    <div class="mb-3">
                        <label for="policyDescription" class="form-label">Описание:</label>
                        <textarea class="form-control" id="policyDescription" name="Description" rows="3"></textarea>
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="policyIsActive" name="IsActive" checked>
                        <label class="form-check-label" for="policyIsActive">Активна</label>
                    </div>
                    <div class="mb-3">
                        <label for="blockedWebsites" class="form-label">Блокирани уебсайтове (по един на ред):</label>
                        <textarea class="form-control" id="blockedWebsites" name="BlockedWebsites" rows="5" placeholder="facebook.com&#10;twitter.com&#10;instagram.com"></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="blockedApplications" class="form-label">Блокирани приложения (по един на ред):</label>
                        <textarea class="form-control" id="blockedApplications" name="BlockedApplications" rows="5" placeholder="chrome&#10;firefox"></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="targetMachines" class="form-label">Целеви машини (по един на ред, празно = всички):</label>
                        <textarea class="form-control" id="targetMachines" name="TargetMachines" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="targetUsers" class="form-label">Целеви потребители (по един на ред, празно = всички):</label>
                        <textarea class="form-control" id="targetUsers" name="TargetUsers" rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отказ</button>
                <button type="button" class="btn btn-primary" onclick="savePolicy()">Запази</button>
            </div>
        </div>
    </div>
</div>

<script>
    async function savePolicy() {
        const form = document.getElementById('policyForm');
        const formData = new FormData(form);
        
        const policy = {
            Id: parseInt(document.getElementById('policyId').value) || 0,
            Name: document.getElementById('policyName').value,
            Description: document.getElementById('policyDescription').value,
            IsActive: document.getElementById('policyIsActive').checked,
            BlockedWebsites: document.getElementById('blockedWebsites').value.split('\n').filter(s => s.trim()),
            BlockedApplications: document.getElementById('blockedApplications').value.split('\n').filter(s => s.trim()),
            TargetMachines: document.getElementById('targetMachines').value.split('\n').filter(s => s.trim()),
            TargetUsers: document.getElementById('targetUsers').value.split('\n').filter(s => s.trim()),
            BlockedFileExtensions: [],
            AllowedInstallations: [],
            BlockedInstallations: [],
            MaxScreenTimeSeconds: 0,
            BlockUsbAccess: false,
            BlockPrinterAccess: false,
            BlockBluetoothAccess: false
        };

        const url = policy.Id > 0 ? `/api/Policy/${policy.Id}` : '/api/Policy';
        const method = policy.Id > 0 ? 'PUT' : 'POST';

        // Валидация
        if (!policy.Name || policy.Name.trim() === '') {
            alert('Моля, въведете име на политиката');
            return;
        }

        try {
            const response = await fetch(url, {
                method: method,
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(policy)
            });

            if (response.ok) {
                // Затваряне на модала
                const modal = bootstrap.Modal.getInstance(document.getElementById('createPolicyModal'));
                if (modal) {
                    modal.hide();
                }
                // Презареждане на страницата
                location.reload();
            } else {
                const errorData = await response.json().catch(() => ({ message: 'Неизвестна грешка' }));
                alert('Грешка при запазване на политиката: ' + (errorData.message || response.statusText));
                console.error('API Error:', response.status, errorData);
            }
        } catch (error) {
            alert('Грешка: ' + error.message);
            console.error('Network Error:', error);
        }
    }

    async function editPolicy(id) {
        try {
            const response = await fetch(`/api/Policy/${id}`);
            const policy = await response.json();
            
            document.getElementById('policyId').value = policy.id;
            document.getElementById('policyName').value = policy.name;
            document.getElementById('policyDescription').value = policy.description || '';
            document.getElementById('policyIsActive').checked = policy.isActive;
            document.getElementById('blockedWebsites').value = (policy.blockedWebsites || []).join('\n');
            document.getElementById('blockedApplications').value = (policy.blockedApplications || []).join('\n');
            document.getElementById('targetMachines').value = (policy.targetMachines || []).join('\n');
            document.getElementById('targetUsers').value = (policy.targetUsers || []).join('\n');
            
            document.getElementById('policyModalTitle').textContent = 'Редактирай политика';
            new bootstrap.Modal(document.getElementById('createPolicyModal')).show();
        } catch (error) {
            alert('Грешка при зареждане на политиката: ' + error.message);
        }
    }

    async function deletePolicy(id) {
        if (!confirm('Сигурни ли сте, че искате да изтриете тази политика?')) {
            return;
        }

        try {
            const response = await fetch(`/api/Policy/${id}`, {
                method: 'DELETE'
            });

            if (response.ok) {
                location.reload();
            } else {
                alert('Грешка при изтриване на политиката');
            }
        } catch (error) {
            alert('Грешка: ' + error.message);
        }
    }

    // Функция за ресетване на формата при отваряне на модала за създаване
    document.getElementById('createPolicyModal').addEventListener('show.bs.modal', function() {
        // Ресетване на формата
        document.getElementById('policyForm').reset();
        document.getElementById('policyId').value = '0';
        document.getElementById('policyModalTitle').textContent = 'Създай нова политика';
        document.getElementById('policyIsActive').checked = true;
    });
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

