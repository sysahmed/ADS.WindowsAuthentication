@{
    Layout = null;
    ViewData["Title"] = "Системни логове";
    var machines = ViewBag.Machines as List<string> ?? new List<string>();
    var machineName = ViewBag.MachineName as string;
    var level = ViewBag.Level as string;
    var logs = ViewBag.Logs as List<ADS.WindowsAuth.Core.Data.Entities.LogEntryEntity> ?? new List<ADS.WindowsAuth.Core.Data.Entities.LogEntryEntity>();
    var levelStats = ViewBag.LevelStats as List<ADS.WindowsAuth.API.Controllers.LevelStat> ?? new List<ADS.WindowsAuth.API.Controllers.LevelStat>();
    var page = ViewBag.Page as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
}
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ADS Windows Authentication</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: #f5f5f5;
            padding-top: 20px;
        }
        .navbar {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            margin-bottom: 20px;
        }
        .navbar-brand {
            color: white !important;
            font-weight: 700;
        }
        .nav-link {
            color: rgba(255,255,255,0.8) !important;
        }
        .nav-link:hover {
            color: white !important;
        }
        .log-entry {
            font-family: 'Courier New', monospace;
            font-size: 0.9em;
        }
        .log-ERROR {
            background-color: #fee;
            border-left: 4px solid #dc3545;
        }
        .log-WARNING {
            background-color: #fff3cd;
            border-left: 4px solid #ffc107;
        }
        .log-INFO {
            background-color: #d1ecf1;
            border-left: 4px solid #17a2b8;
        }
        .badge-level {
            font-size: 0.75em;
            padding: 0.25em 0.5em;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="/">🔐 ADS Windows Auth</a>
            <div class="navbar-nav">
                <a class="nav-link" href="/">🏠 Начало</a>
                <a class="nav-link" href="/policies">🔒 Политики</a>
                <a class="nav-link" href="/monitor-settings">⚙️ Настройки</a>
                <a class="nav-link" href="/logs">📊 Активност</a>
                <a class="nav-link active" href="/system-logs">📝 Логове</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row">
            <div class="col-md-12">
                <h2 class="mb-4">📝 Системни логове</h2>
            </div>
        </div>

        <div class="row">
            <div class="col-md-3">
                <div class="card">
                    <div class="card-header">
                        <h5>Филтри</h5>
                    </div>
                    <div class="card-body">
                        <form method="get" action="/system-logs">
                            <div class="mb-3">
                                <label for="machineName" class="form-label">Машина:</label>
                                <select class="form-select" id="machineName" name="machineName">
                                    <option value="">-- Всички машини --</option>
                                    @foreach (var machine in machines)
                                    {
                                        if (machine == machineName)
                                        {
                                            <option value="@machine" selected>@machine</option>
                                        }
                                        else
                                        {
                                            <option value="@machine">@machine</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label for="level" class="form-label">Ниво:</label>
                                <select class="form-select" id="level" name="level">
                                    <option value="">-- Всички нива --</option>
                                    @if (level == "ERROR")
                                    {
                                        <option value="ERROR" selected>ERROR</option>
                                    }
                                    else
                                    {
                                        <option value="ERROR">ERROR</option>
                                    }
                                    @if (level == "WARNING")
                                    {
                                        <option value="WARNING" selected>WARNING</option>
                                    }
                                    else
                                    {
                                        <option value="WARNING">WARNING</option>
                                    }
                                    @if (level == "INFO")
                                    {
                                        <option value="INFO" selected>INFO</option>
                                    }
                                    else
                                    {
                                        <option value="INFO">INFO</option>
                                    }
                                </select>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Приложи филтри</button>
                            <a href="/system-logs" class="btn btn-secondary w-100 mt-2">Изчисти</a>
                        </form>
                    </div>
                </div>

                @if (levelStats.Any())
                {
                    <div class="card mt-3">
                        <div class="card-header">
                            <h5>Статистика</h5>
                        </div>
                        <div class="card-body">
                            @foreach (var stat in levelStats)
                            {
                                <div class="d-flex justify-content-between mb-2">
                                    <span>@stat.Level:</span>
                                    <strong>@stat.Count</strong>
                                </div>
                            }
                            <hr>
                            <div class="d-flex justify-content-between">
                                <strong>Общо:</strong>
                                <strong>@totalCount</strong>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="col-md-9">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5>Логове @(string.IsNullOrEmpty(machineName) ? "" : $"за {machineName}")</h5>
                        <span class="badge bg-secondary">@totalCount общо</span>
                    </div>
                    <div class="card-body">
                        @if (logs.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Време</th>
                                            <th>Ниво</th>
                                            <th>Машина</th>
                                            <th>Потребител</th>
                                            <th>Източник</th>
                                            <th>Съобщение</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var log in logs)
                                        {
                                            <tr class="log-entry log-@(log?.Level ?? "INFO")">
                                                <td>@(log?.Timestamp.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                                                <td>
                                                    <span class="badge @((log?.Level ?? "INFO") == "ERROR" ? "bg-danger" : (log?.Level ?? "INFO") == "WARNING" ? "bg-warning" : "bg-info") badge-level">
                                                        @(log?.Level ?? "INFO")
                                                    </span>
                                                </td>
                                                <td>@(log?.MachineName ?? "-")</td>
                                                <td>@(log?.Username ?? "-")@@@(log?.Domain ?? "-")</td>
                                                <td>@(log?.Source ?? "-")</td>
                                                <td>
                                                    <div style="max-width: 400px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@(log?.Message ?? "")">
                                                        @(log?.Message ?? "-")
                                                    </div>
                                                    @if (!string.IsNullOrEmpty(log?.ExceptionType))
                                                    {
                                                        <small class="text-danger">@log.ExceptionType</small>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            @if (totalPages > 1)
                            {
                                <nav>
                                    <ul class="pagination justify-content-center">
                                        @if (page > 1)
                                        {
                                            <li class="page-item">
                                                <a class="page-link" href="?machineName=@machineName&level=@level&page=@(page - 1)">Предишна</a>
                                            </li>
                                        }
                                        @for (int i = Math.Max(1, page - 2); i <= Math.Min(totalPages, page + 2); i++)
                                        {
                                            <li class="page-item @(i == page ? "active" : "")">
                                                <a class="page-link" href="?machineName=@machineName&level=@level&page=@i">@i</a>
                                            </li>
                                        }
                                        @if (page < totalPages)
                                        {
                                            <li class="page-item">
                                                <a class="page-link" href="?machineName=@machineName&level=@level&page=@(page + 1)">Следваща</a>
                                            </li>
                                        }
                                    </ul>
                                </nav>
                            }
                        }
                        else
                        {
                            <div class="alert alert-info">
                                Няма намерени логове с избраните филтри.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

