<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" 
           Name="ADS Windows Auth Credential Provider" 
           Language="1033" 
           Version="1.0.0.0" 
           Manufacturer="ADS" 
           UpgradeCode="A1B2C3D4-E5F6-4A5B-8C9D-0E1F2A3B4C5D">
    
    <Package InstallerVersion="200" 
             Compressed="yes" 
             InstallScope="perMachine" 
             Description="ADS Windows Authentication Credential Provider" 
             Manufacturer="ADS" />
    
    <MajorUpgrade DowngradeErrorMessage="По-нова версия е вече инсталирана." />
    
    <MediaTemplate />
    
    <!-- Директория за инсталация - C:\ADS -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ADSFolder" Name="ADS">
        <Directory Id="CredentialProviderFolder" Name="CredentialProvider" />
      </Directory>
    </Directory>
    
    <!-- SetDirectory за да използваме C:\ADS -->
    <SetDirectory Id="ADSFolder" Value="C:\ADS" />
    
    <!-- Компоненти -->
    <ComponentGroup Id="CredentialProviderFiles" Directory="CredentialProviderFolder">
      <Component Id="CredentialProviderDLL" Guid="B1C2D3E4-F5A6-4B7C-8D9E-0F1A2B3C4D5E">
        <File Id="CredentialProviderDLLFile" 
              Source="..\bin\x64\Release\ADS.WindowsAuth.CredentialProvider.dll" 
              KeyPath="yes" />
        
        <!-- Registry за ServiceUrl -->
        <RegistryKey Root="HKLM" Key="SOFTWARE\ADS\WindowsAuth">
          <RegistryValue Name="ServiceUrl" 
                        Type="string" 
                        Value="https://ads-auth.nursanbulgaria.com" />
        </RegistryKey>
      </Component>
      
      <!-- PowerShell скрипт за регистрация -->
      <Component Id="RegisterScript" Guid="C2D3E4F5-A6B7-4C8D-9E0F-1A2B3C4D5E6F">
        <File Id="RegisterScriptFile" 
              Source="..\REGISTER.ps1" 
              KeyPath="yes" />
      </Component>
    </ComponentGroup>
    
    <!-- Функционалност -->
    <Feature Id="CredentialProviderFeature" Title="Credential Provider" Level="1">
      <ComponentGroupRef Id="CredentialProviderFiles" />
    </Feature>
    
    <!-- Custom Actions за регистрация/деинсталация -->
    <!-- SetProperty за да получим пътя -->
    <SetProperty Id="RegisterDLL" 
                 Value="regsvr32.exe /s &quot;[CredentialProviderFolder]ADS.WindowsAuth.CredentialProvider.dll&quot;"
                 After="InstallFiles"
                 Sequence="execute">
      NOT Installed
    </SetProperty>
    
    <SetProperty Id="UnregisterDLL" 
                 Value="regsvr32.exe /s /u &quot;[CredentialProviderFolder]ADS.WindowsAuth.CredentialProvider.dll&quot;"
                 Before="RemoveFiles"
                 Sequence="execute">
      REMOVE="ALL"
    </SetProperty>
    
    <!-- Custom Actions -->
    <CustomAction Id="RegisterCredentialProvider" 
                  Property="RegisterDLL"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />
    
    <CustomAction Id="UnregisterCredentialProvider" 
                  Property="UnregisterDLL"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />
    
    <InstallExecuteSequence>
      <Custom Action="RegisterCredentialProvider" After="InstallFiles">
        NOT Installed
      </Custom>
      <Custom Action="UnregisterCredentialProvider" Before="RemoveFiles">
        REMOVE="ALL"
      </Custom>
    </InstallExecuteSequence>
    
    <!-- UI -->
    <UIRef Id="WixUI_Minimal" />
    
  </Product>
</Wix>

