@using ADS.WindowsAuth.API.Data
@using ADS.WindowsAuth.Core.Models
@model PortalUser
@{
    ViewData["Title"] = "Моят Профил";
    Layout = "_Layout";
    var credentials = ViewData["Credentials"] as IEnumerable<Fido2Credential>
                      ?? Enumerable.Empty<Fido2Credential>();
}

<div class="container mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row g-4">
        <!-- Профил -->
        <div class="col-md-5">
            <div class="glass-card p-4 text-center">
                <div style="font-size:4rem;">👤</div>
                <h4 class="mt-2">@(Model.DisplayName ?? Model.UserName)</h4>
                <p class="text-muted mb-1">@Model.Email</p>
                <span class="badge bg-primary">@Model.Role</span>
                <hr />
                <div class="text-start small">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Потребителско Иmе:</span>
                        <strong>@Model.UserName</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Регистриран:</span>
                        <strong>@Model.CreatedAt.ToString("dd.MM.yyyy")</strong>
                    </div>
                    @if (Model.LastLoginAt.HasValue)
                    {
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Последен вход:</span>
                            <strong>@Model.LastLoginAt.Value.ToString("dd.MM.yyyy HH:mm")</strong>
                        </div>
                    }
                </div>
                <div class="mt-3">
                    <form asp-action="Logout" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                            🚪 Изход
                        </button>
                    </form>
                </div>
            </div>

            <!-- Промяна на имейл и име -->
            <div class="glass-card p-4 mt-3">
                <h5 class="mb-3">✏️ Редактирай профил</h5>
                <form asp-action="UpdateProfile" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Имейл</label>
                        <input name="Email" type="email" class="form-control" value="@Model.Email" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Пълно Име</label>
                        <input name="DisplayName" class="form-control" value="@(Model.DisplayName ?? "")" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Запази</button>
                </form>
            </div>

            <!-- Смяна на парола -->
            <div class="glass-card p-4 mt-3">
                <h5 class="mb-3">🔒 Смяна на парола</h5>
                <form asp-action="ChangePassword" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Текуща парола</label>
                        <input name="CurrentPassword" type="password" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Нова парола (мин. 8 символа)</label>
                        <input name="NewPassword" type="password" class="form-control" required minlength="8" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Потвърди нова парола</label>
                        <input name="ConfirmPassword" type="password" class="form-control" required />
                    </div>
                    <button type="submit" class="btn btn-warning w-100">Смени парола</button>
                </form>
            </div>
        </div>

        <!-- FIDO2 устройства -->
        <div class="col-md-7">
            <div class="glass-card p-4">
                <div class="d-flex align-items-center mb-3">
                    <span style="font-size:1.5rem; margin-right:0.75rem;">🔏</span>
                    <h5 class="mb-0">Биометрични устройства</h5>
                    <a href="/WebAuthn/Register" class="btn btn-sm btn-primary ms-auto">
                        + Добави
                    </a>
                </div>

                @if (credentials.Any())
                {
                    <div class="list-group">
                        @foreach (var cred in credentials)
                        {
                            <div class="list-group-item list-group-item-action d-flex align-items-center" style="background:rgba(255,255,255,0.05); border-color:rgba(255,255,255,0.1);">
                                <span style="font-size:1.5rem; margin-right:0.75rem;">📱</span>
                                <div class="flex-grow-1">
                                    <strong>@(cred.DeviceDescription ?? "WebAuthn Device")</strong>
                                    <br />
                                    <small class="text-muted">
                                        Добавен: @cred.CreatedAt.ToString("dd.MM.yyyy")
                                        @if (cred.LastUsedAt != default)
                                        {
                                            <span> · Последно: @cred.LastUsedAt.ToString("dd.MM.yyyy")</span>
                                        }
                                    </small>
                                </div>
                                <button class="btn btn-sm btn-outline-danger"
                                        onclick="deleteCredential('@cred.CredentialId')">
                                    🗑
                                </button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <div style="font-size:2.5rem;">🔓</div>
                        <p class="mt-2">Нямате регистрирани биометрични устройства.</p>
                        <a href="/WebAuthn/Register" class="btn btn-primary btn-sm">
                            Добави устройство
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
async function deleteCredential(credentialId) {
    if (!confirm('Сигурни ли сте, че искате да премахнете това устройство?')) return;
    try {
        const resp = await fetch(`/api/webauthn/credentials/${credentialId}`, { method: 'DELETE' });
        if (!resp.ok) throw new Error('Грешка при изтриване');
        window.location.reload();
    } catch (e) {
        alert('Грешка: ' + e.message);
    }
}
</script>
}
