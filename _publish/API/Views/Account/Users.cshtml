@{
    ViewData["Title"] = "Управление на потребители";
    Layout = "_Layout";
    var users = ViewBag.Users as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<div class="container mt-4">
    <div class="d-flex align-items-center mb-4">
        <div>
            <h3 class="mb-0">👥 Потребители</h3>
            <small class="text-muted">Управление на Portal акаунти</small>
        </div>
        <a href="/Account/Register" class="btn btn-primary ms-auto">
            <i class="bi bi-person-plus"></i> Нов потребител
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="glass-card p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Потребител</th>
                        <th>Имейл</th>
                        <th>Роля</th>
                        <th>FIDO2</th>
                        <th>Последен вход</th>
                        <th>Статус</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in users)
                    {
                        <tr>
                            <td>
                                <strong>@u.UserName</strong>
                                @if (!string.IsNullOrEmpty((string?)u.DisplayName))
                                {
                                    <br /><small class="text-muted">@u.DisplayName</small>
                                }
                            </td>
                            <td><small>@u.Email</small></td>
                            <td>
                                @{
                                    var roleClass = (string)u.Role switch
                                    {
                                        "Admin" => "badge bg-danger",
                                        "Monitor" => "badge bg-info",
                                        _ => "badge bg-secondary"
                                    };
                                }
                                <span class="@roleClass">@u.Role</span>
                            </td>
                            <td>
                                @if ((bool)u.hasFido2)
                                {
                                    <span class="badge bg-success">🔏 Да</span>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td>
                                @if (u.LastLoginAt != null)
                                {
                                    <small>@((DateTime)u.LastLoginAt).ToString("dd.MM.yyyy HH:mm")</small>
                                }
                                else
                                {
                                    <small class="text-muted">Никога</small>
                                }
                            </td>
                            <td>
                                @if ((bool)u.IsActive)
                                {
                                    <span class="badge bg-success">Активен</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Блокиран</span>
                                }
                            </td>
                            <td class="text-nowrap">
                                <a href="/Account/Edit/@u.Id" class="btn btn-sm btn-outline-primary me-1">✏️ Редактирай</a>
                                <button class="btn btn-sm @((bool)u.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                        onclick="toggleUser('@u.Id', this)">
                                    @((bool)u.IsActive ? "🔒 Блокирай" : "🔓 Активирай")
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!users.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">Няма регистрирани потребители</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
async function toggleUser(id, btn) {
    try {
        btn.disabled = true;
        const resp = await fetch(`/api/account/users/${id}/toggle`, { method: 'POST' });
        if (!resp.ok) throw new Error('Грешка');
        window.location.reload();
    } catch (e) {
        alert('Грешка: ' + e.message);
        btn.disabled = false;
    }
}
</script>
}
