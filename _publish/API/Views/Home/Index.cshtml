@{
    ViewData["Title"] = "ADS Windows Authentication";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12 text-center mb-5 fade-in">
            <h1 class="display-3 mb-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-weight: 800;">
                🔐 ADS Windows Authentication
            </h1>
            <p class="lead text-white" style="font-size: 1.25rem; text-shadow: 0 2px 4px rgba(0,0,0,0.2);">
                Система за управление на Windows машини в домейн
            </p>
        </div>
    </div>

    <!-- Login секция – биометрия (Touch ID / Face ID) + парола -->
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="glass-card fade-in">
                <div class="d-flex align-items-center mb-4">
                    <div style="font-size: 2rem; margin-right: 1rem;">🔐</div>
                    <div>
                        <h5 class="mb-1">Вход в системата</h5>
                        <p class="text-muted mb-0 small">Вход с биометрия на мобилен или парола</p>
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <a href="/WebAuthn/Login" class="btn btn-primary btn-lg w-100 d-flex align-items-center justify-content-center gap-2" style="font-weight:600;">
                            <i class="bi bi-fingerprint"></i> Биометричен вход
                        </a>
                        <p class="text-muted small mt-1 mb-0 text-center">Touch ID, Face ID, Windows Hello</p>
                    </div>
                    <div class="col-md-6">
                        <a href="/auth" class="btn btn-outline-primary btn-lg w-100 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-key"></i> Вход с парола / QR код
                        </a>
                        <p class="text-muted small mt-1 mb-0 text-center">Домейн credentials или QR сканиране</p>
                    </div>
                    <div class="col-12 text-center">
                        <a href="/WebAuthn/Register" class="btn btn-link btn-sm text-muted">
                            <i class="bi bi-plus-circle"></i> Първо път? Регистрирай устройство за биометрия
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Къде е влизано + Какво се пише – на едно място -->
    <div class="row mt-4">
        <div class="col-md-12">
            <h4 class="text-white mb-3">👁️ Къде е влизано и какво се пише</h4>
        </div>
        <div class="col-md-6">
            <div class="glass-card fade-in" style="border-left: 4px solid #0d6efd;">
                <h5 class="mb-2"><i class="bi bi-box-arrow-in-right text-primary"></i> Къде е влизано</h5>
                <p class="text-muted small mb-3">Вижте <strong>кой</strong>, <strong>кога</strong> и <strong>на коя машина</strong> е влязъл в Windows. Данните идват от Monitor (Windows Security Event Log).</p>
                <a href="/login-events" class="btn btn-primary w-100">Виж влизания</a>
            </div>
        </div>
        <div class="col-md-6">
            <div class="glass-card fade-in" style="border-left: 4px solid #198754;">
                <h5 class="mb-2"><i class="bi bi-keyboard text-success"></i> Какво се пише (клавиши и кликове)</h5>
                <p class="text-muted small mb-3">Вижте <strong>какво се въвежда</strong> и <strong>в кое приложение</strong> (Chrome, Word и др.). <strong>За да има данни:</strong> на всяка машина трябва да работи <strong>ADS Client</strong> в сесията на потребителя – без Client тук няма да има записи.</p>
                <a href="/input-logs" class="btn btn-success w-100">Виж въвеждане и кликове</a>
            </div>
        </div>
    </div>

    <div class="row mt-4 mb-5">
        <div class="col-md-12">
            <div class="glass-card fade-in" style="animation-delay: 0.2s;">
                <div class="d-flex align-items-center mb-4">
                    <div style="font-size: 2rem; margin-right: 1rem;">🔗</div>
                    <h5 class="mb-0">Полезни линкове</h5>
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <a href="/monitor" class="btn btn-primary w-100 d-flex align-items-center justify-content-center gap-2" style="font-weight:600;">
                            <i class="bi bi-pc-display-horizontal"></i> 🖥️ Монитор на машини
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="/performance" class="btn btn-outline-primary w-100 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-graph-up"></i> Анализ на продуктивност
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="/logs" class="btn btn-outline-primary w-100 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-file-text"></i> Логове по машина
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="/auth" class="btn btn-outline-primary w-100 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-qr-code"></i> QR Код Аутентикация
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="/RemoteDesktop" class="btn btn-outline-primary w-100 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-display"></i> Remote Desktop
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="/monitor-settings" class="btn btn-outline-primary w-100 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-gear"></i> Настройки на Monitor
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="/system-logs" class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-journal-code"></i> Системни логове
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="/login-events" class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-box-arrow-in-right"></i> Windows влизания
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="/input-logs" class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-keyboard"></i> Въвеждане и кликове
                        </a>
                        <small class="text-muted d-block mt-1">Клавиши и мишка по приложения – изисква <strong>Client</strong> в сесията на потребителя</small>
                    </div>
                    <div class="col-md-6">
                        <a href="/policies" class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-shield-lock"></i> Политики
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="/swagger" class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-book"></i> API Документация
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Инсталационни файлове и инструкции – най-долу -->
    <div class="row mt-4 g-4">
        <div class="col-md-6">
            <div class="glass-card scale-in">
                <div style="font-size: 3rem; text-align: center; margin-bottom: 1rem;">📱</div>
                <h5 class="card-title text-center mb-3">Windows Forms Клиент</h5>
                <p class="card-text text-center mb-4">
                    Изтеглете Windows Forms приложението за управление на QR код аутентикация.
                </p>
                <div class="text-center">
                    <a href="/download/client" class="btn btn-primary btn-lg">
                        <i class="bi bi-download"></i> Изтегли клиент
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="glass-card scale-in" style="animation-delay: 0.1s;">
                <div style="font-size: 3rem; text-align: center; margin-bottom: 1rem;">⚙️</div>
                <h5 class="card-title text-center mb-3">Автоматична инсталация</h5>
                <p class="card-text text-center mb-4">
                    PowerShell скрипт за автоматична инсталация на всички компоненти.
                </p>
                <div class="text-center">
                    <a href="/download/installer" class="btn btn-success btn-lg">
                        <i class="bi bi-download"></i> Изтегли инсталатор
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4 mb-5">
        <div class="col-md-12">
            <div class="glass-card fade-in" style="animation-delay: 0.2s;">
                <div class="d-flex align-items-center mb-4">
                    <div style="font-size: 2rem; margin-right: 1rem;">📋</div>
                    <h5 class="mb-0">Инструкции за инсталация</h5>
                </div>
                <ol class="installation-steps">
                    <li class="mb-4">
                        <strong>Изтеглете инсталационния скрипт:</strong>
                        <div class="mt-2 position-relative">
                            <code class="d-block p-3 bg-light rounded" style="border-left: 4px solid var(--primary);">
                                Invoke-WebRequest -Uri "https://ads-auth.nursanbulgaria.com/download/installer" -OutFile "Install-ADS.ps1"
                            </code>
                        </div>
                    </li>
                    <li class="mb-4">
                        <strong>Стартирайте скрипта като администратор:</strong>
                        <div class="mt-2">
                            <code class="d-block p-3 bg-light rounded" style="border-left: 4px solid var(--success);">
                                .\Install-ADS.ps1
                            </code>
                        </div>
                    </li>
                    <li class="mb-4">
                        <strong>Скриптът автоматично ще:</strong>
                        <ul class="mt-2">
                            <li>Създаде необходимите директории</li>
                            <li>Изтегли Windows Forms клиент</li>
                            <li>Инсталира Monitor Service</li>
                            <li>Регистрира Credential Provider DLL (ако е наличен)</li>
                            <li>Конфигурира настройките</li>
                        </ul>
                    </li>
                    <li>
                        <strong>Рестартирайте компютъра</strong> за да активирате Credential Provider
                    </li>
                </ol>
            </div>
        </div>
    </div>
</div>

<style>
.installation-steps {
    counter-reset: step-counter;
    list-style: none;
    padding-left: 0;
}

.installation-steps > li {
    counter-increment: step-counter;
    position: relative;
    padding-left: 3rem;
}

.installation-steps > li::before {
    content: counter(step-counter);
    position: absolute;
    left: 0;
    top: 0;
    width: 2rem;
    height: 2rem;
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 1.1rem;
}

.installation-steps ul {
    margin-top: 0.5rem;
}
</style>
