@using ADS.WindowsAuth.Core.Data.Entities
@{
    Layout = "_Layout";
    ViewData["Title"] = "Въвеждане и кликове";
    var items = ViewBag.Items as List<InputLogEntity> ?? new List<InputLogEntity>();
    var machines = ViewBag.Machines as List<string> ?? new List<string>();
    var machineName = ViewBag.MachineName as string;
    var username = ViewBag.Username as string;
    var logType = ViewBag.LogType as string;
    var dateFrom = ViewBag.DateFrom as string;
    var dateTo = ViewBag.DateTo as string;
    var page = ViewBag.Page as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
    var pageSize = ViewBag.PageSize as int? ?? 100;
    var errorMessage = ViewBag.ErrorMessage as string;
    var isOnlyTestData = ViewBag.IsOnlyTestData as bool? ?? false;
}
<div class="container mt-4 mb-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2 class="mb-2">⌨️ Какво се пише (въвеждане и кликове)</h2>
            <p class="text-muted mb-0">Вижте <strong>какво се въвежда</strong> и <strong>в кое приложение</strong> (Chrome, Word и др.). За да има данни: на машината трябва да работи <strong>ADS Client</strong> в сесията на потребителя.</p>
        </div>
    </div>
    <div class="alert alert-light border mb-3 py-2">
        <strong>Бърз линк:</strong> <a href="/login-events">Къде е влизано</a> (кой, кога и на коя машина е влязъл)
    </div>
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-warning mb-4" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
        </div>
    }
    @if (isOnlyTestData)
    {
        <div class="alert alert-info mb-4" role="alert">
            <strong><i class="bi bi-info-circle me-2"></i>Това са само тестови записи</strong> (от <code>/api/logs/input-test-add</code>). Не са реални клавиши/кликове от потребител. Реални данни ще се появят когато <strong>ADS Client</strong> работи в сесията на потребителя на някоя машина – тогава тук ще виждате записи под името на този потребител. Можете да изтриете тестовите записи директно от базата данни (таблица <code>InputLogs</code>, потребител <code>TestUser</code>), ако искате да останат само реални данни.
        </div>
    }
    <div class="d-flex flex-wrap gap-2 mb-4">
        <a href="/" class="btn btn-outline-primary btn-sm"><i class="bi bi-house"></i> Начало</a>
        <a href="/system-logs" class="btn btn-outline-primary btn-sm"><i class="bi bi-journal-code"></i> Системни логове</a>
        <a href="/login-events" class="btn btn-outline-secondary btn-sm"><i class="bi bi-box-arrow-in-right"></i> Windows влизания</a>
    </div>
    <div class="card shadow-sm mb-4">
        <div class="card-header"><h5 class="mb-0">Филтри</h5></div>
        <div class="card-body">
            <form method="get" action="/input-logs" class="row g-3">
                <div class="col-md-2">
                    <label class="form-label">Машина</label>
                    <select name="machineName" class="form-select">
                        <option value="">-- Всички --</option>
                        @foreach (var m in machines)
                        {
                            if (m == machineName)
                            {
                                <option value="@m" selected>@m</option>
                            }
                            else
                            {
                                <option value="@m">@m</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Потребител</label>
                    <input type="text" name="username" class="form-control" value="@username" placeholder="съдържа" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Тип</label>
                    <select name="logType" class="form-select">
                        <option value="">Всички</option>
                        @if (logType == "Key")
                        {
                            <option value="Key" selected>Клавиш</option>
                        }
                        else
                        {
                            <option value="Key">Клавиш</option>
                        }
                        @if (logType == "Click")
                        {
                            <option value="Click" selected>Клик</option>
                        }
                        else
                        {
                            <option value="Click">Клик</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">От дата</label>
                    <input type="date" name="dateFrom" class="form-control" value="@dateFrom" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">До дата</label>
                    <input type="date" name="dateTo" class="form-control" value="@dateTo" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">Приложи</button>
                    <a href="/input-logs" class="btn btn-secondary">Изчисти</a>
                </div>
            </form>
        </div>
    </div>
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Записи <span class="badge bg-secondary">@totalCount общо</span></h5>
        </div>
        <div class="card-body">
            @if (items.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover">
                        <thead>
                            <tr>
                                <th style="width: 155px;">Време</th>
                                <th>Машина</th>
                                <th>Потребител</th>
                                <th style="width: 70px;">Тип</th>
                                <th>Приложение</th>
                                <th>Прозорец / Данни</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in items)
                            {
                                <tr>
                                    <td>@e.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td>@e.MachineName</td>
                                    <td>@e.Username@@@e.Domain</td>
                                    <td><span class="badge @(e.LogType == "Click" ? "bg-info" : "bg-secondary")">@e.LogType</span></td>
                                    <td title="@e.ApplicationName">@(e.ApplicationName != null && e.ApplicationName.Length > 25 ? e.ApplicationName.Substring(0, 22) + "…" : e.ApplicationName)</td>
                                    <td>
                                        @if (e.IsPassword)
                                        {
                                            <span class="text-muted">***</span>
                                        }
                                        else
                                        {
                                            <span title="@e.Data">@(e.Data != null && e.Data.Length > 60 ? e.Data.Substring(0, 57) + "…" : e.Data)</span>
                                            @if (!string.IsNullOrEmpty(e.WindowTitle) && e.WindowTitle != e.Data)
                                            {
                                                <br /><small class="text-muted" title="@e.WindowTitle">@(e.WindowTitle.Length > 50 ? e.WindowTitle.Substring(0, 47) + "…" : e.WindowTitle)</small>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (totalPages > 1)
                {
                    <nav class="mt-2">
                        <ul class="pagination pagination-sm mb-0">
                            @if (page > 1)
                            {
                                <li class="page-item"><a class="page-link" href="/input-logs?machineName=@Uri.EscapeDataString(machineName ?? "")&username=@Uri.EscapeDataString(username ?? "")&logType=@Uri.EscapeDataString(logType ?? "")&dateFrom=@Uri.EscapeDataString(dateFrom ?? "")&dateTo=@Uri.EscapeDataString(dateTo ?? "")&page=@(page - 1)&pageSize=@pageSize">←</a></li>
                            }
                            <li class="page-item disabled"><span class="page-link">Стр. @(page) от @totalPages</span></li>
                            @if (page < totalPages)
                            {
                                <li class="page-item"><a class="page-link" href="/input-logs?machineName=@Uri.EscapeDataString(machineName ?? "")&username=@Uri.EscapeDataString(username ?? "")&logType=@Uri.EscapeDataString(logType ?? "")&dateFrom=@Uri.EscapeDataString(dateFrom ?? "")&dateTo=@Uri.EscapeDataString(dateTo ?? "")&page=@(page + 1)&pageSize=@pageSize">→</a></li>
                            }
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="alert alert-warning mb-0">
                    <strong>Няма записи за клавиши и кликове.</strong>
                    <ol class="mb-2 mt-2 ps-3">
                        <li><strong>Стартирайте ADS.WindowsAuth.Client</strong> на компютъра на потребителя (не само Monitor услугата). Client при отваряне стартира прихващането и изпраща към API.</li>
                        <li>Уверете се, че в Client <code>appsettings.json</code> има <code>ApiConfiguration:BaseUrl</code> = URL на API (напр. https://ads-auth.nursanbulgaria.com).</li>
                        <li>Таблицата <strong>InputLogs</strong> трябва да съществува в базата – вижте <code>Scripts/CreateTables-FromProgram.sql</code>.</li>
                    </ol>
                    <p class="mb-0">
                        <strong>Тест:</strong> <a href="/api/logs/input-test-add" target="_blank">/api/logs/input-test-add</a> – вмъква един тестов запис. Ако след това виждате запис тук (изберете машината от филтъра), таблицата и порталът работят; реалните данни ще идват когато Client работи на машината на потребителя.
                    </p>
                </div>
            }
        </div>
    </div>
</div>
