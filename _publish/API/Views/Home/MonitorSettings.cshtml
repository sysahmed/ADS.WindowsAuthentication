@{
    Layout = "_Layout";
    ViewData["Title"] = "Настройки на Monitor Service";
    var machines = ViewBag.Machines as List<string> ?? new List<string>();
    var selectedMachine = ViewBag.SelectedMachine as string;
    var configuration = ViewBag.Configuration as ADS.WindowsAuth.API.Controllers.MonitorConfigurationResponse;
    var vpnProcessDisplay = "FortiClient, rasdial";
    if (!string.IsNullOrEmpty(configuration?.VpnProcessNames) && configuration.VpnProcessNames.StartsWith("["))
    {
        try
        {
            var list = System.Text.Json.JsonSerializer.Deserialize<List<string>>(configuration.VpnProcessNames);
            if (list?.Count > 0) vpnProcessDisplay = string.Join(", ", list);
        }
        catch { }
    }
    else if (!string.IsNullOrEmpty(configuration?.VpnProcessNames))
    {
        vpnProcessDisplay = configuration.VpnProcessNames;
    }
}

<div class="container mt-4 mb-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2 class="mb-2">⚙️ Настройки на Monitor Service</h2>
            <p class="text-muted mb-0">Управление на Service URL, VPN проверки, повторни опити и други параметри за всяка машина.</p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-12">
            <div class="d-flex flex-wrap gap-2">
                <a href="/" class="btn btn-outline-primary btn-sm"><i class="bi bi-house"></i> Начало</a>
                <a href="/monitor" class="btn btn-outline-primary btn-sm"><i class="bi bi-pc-display"></i> Монитор</a>
                <a href="/policies" class="btn btn-outline-primary btn-sm"><i class="bi bi-shield-lock"></i> Политики</a>
                <a href="/system-logs" class="btn btn-outline-secondary btn-sm"><i class="bi bi-journal-code"></i> Логове</a>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-hdd-network"></i> Машини</h5>
                </div>
                <div class="card-body">
                    <form method="get" action="/monitor-settings" class="mb-3">
                        <label class="form-label">Избери машина:</label>
                        <select class="form-select" name="machineName" onchange="this.form.submit()">
                            <option value="">-- Избери машина --</option>
                            @foreach (var machine in machines)
                            {
                                if (machine == selectedMachine)
                                {
                                    <option value="@machine" selected>@machine</option>
                                }
                                else
                                {
                                    <option value="@machine">@machine</option>
                                }
                            }
                        </select>
                    </form>

                    <hr />

                    <form method="get" action="/monitor-settings" class="d-flex gap-2">
                        <input type="text" name="machineName" class="form-control" placeholder="Име на нова машина" required minlength="1" />
                        <button type="submit" class="btn btn-success"><i class="bi bi-plus-lg"></i> Добави</button>
                    </form>
                    <small class="text-muted">Въведете име и натиснете Добави за нова машина.</small>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            @if (!string.IsNullOrEmpty(selectedMachine))
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="bi bi-gear"></i> Конфигурация за @selectedMachine</h5>
                    </div>
                    <div class="card-body">
                        <form id="configForm">
                            <input type="hidden" id="configMachineName" value="@selectedMachine" />
                            <div class="row g-3">
                                <div class="col-12">
                                    <label for="serviceUrl" class="form-label">Service URL <span class="text-danger">*</span></label>
                                    <input type="url" class="form-control" id="serviceUrl" value="@(configuration?.ServiceUrl ?? "https://ads-auth.nursanbulgaria.com")" required placeholder="https://ads-auth.nursanbulgaria.com" />
                                    <small class="text-muted">URL на API сървъра. Monitor Service синхронизира конфигурацията на всеки 5 минути.</small>
                                </div>
                                <div class="col-md-6">
                                    <label for="apiKey" class="form-label">API Key (опционално)</label>
                                    <input type="text" class="form-control" id="apiKey" value="@(configuration?.ApiKey ?? "")" />
                                </div>
                                <div class="col-md-6">
                                    <label for="connectionTimeout" class="form-label">Connection Timeout (сек)</label>
                                    <input type="number" class="form-control" id="connectionTimeout" value="@(configuration?.ConnectionTimeout ?? 30)" min="5" max="300" />
                                </div>
                                <div class="col-12">
                                    <div class="form-check form-switch">
                                        <input type="checkbox" class="form-check-input" id="requireVpn" @(configuration?.RequireVpn == true ? "checked" : "") />
                                        <label class="form-check-label" for="requireVpn">Изисква VPN</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label for="vpnCheckInterval" class="form-label">VPN Check Interval (сек)</label>
                                    <input type="number" class="form-control" id="vpnCheckInterval" value="@(configuration?.VpnCheckInterval ?? 300)" min="60" />
                                </div>
                                <div class="col-md-6">
                                    <label for="vpnProcessNames" class="form-label">VPN процеси (разделени със запетая)</label>
                                    <input type="text" class="form-control" id="vpnProcessNames" value="@vpnProcessDisplay" placeholder="FortiClient, rasdial" />
                                </div>
                                <div class="col-12">
                                    <div class="form-check form-switch">
                                        <input type="checkbox" class="form-check-input" id="offlineMode" @(configuration?.OfflineMode == true ? "checked" : "") />
                                        <label class="form-check-label" for="offlineMode">Offline Mode (когато няма връзка)</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label for="offlineDataRetention" class="form-label">Offline Data Retention (дни)</label>
                                    <input type="number" class="form-control" id="offlineDataRetention" value="@(configuration?.OfflineDataRetention ?? 7)" min="1" max="365" />
                                </div>
                                <div class="col-md-6">
                                    <label for="retryInterval" class="form-label">Retry Interval (сек)</label>
                                    <input type="number" class="form-control" id="retryInterval" value="@(configuration?.RetryInterval ?? 60)" min="10" />
                                </div>
                                <div class="col-md-6">
                                    <label for="maxRetries" class="form-label">Max Retries</label>
                                    <input type="number" class="form-control" id="maxRetries" value="@(configuration?.MaxRetries ?? 3)" min="1" max="20" />
                                </div>
                                <div class="col-12">
                                    <hr class="my-1" />
                                    <small class="text-muted fw-semibold">Екранни снимки</small>
                                </div>
                                <div class="col-12">
                                    <div class="form-check form-switch">
                                        <input type="checkbox" class="form-check-input" id="screenshotEnabled" @(configuration?.ScreenshotEnabled == true ? "checked" : "") />
                                        <label class="form-check-label" for="screenshotEnabled">Записване на скрийншот (Screenshot)</label>
                                    </div>
                                    <small class="text-muted">Когато е включено, Monitor Service прави снимки на екрана на потребителя и ги изпраща на сървъра.</small>
                                </div>
                                <div class="col-md-6">
                                    <label for="screenshotIntervalMinutes" class="form-label">Интервал (минути)</label>
                                    <input type="number" class="form-control" id="screenshotIntervalMinutes" value="@(configuration?.ScreenshotIntervalMinutes ?? 5)" min="1" max="60" />
                                    <small class="text-muted">Скрийншот на всеки X минути.</small>
                                </div>
                                <div class="col-12 mt-3">
                                    <button type="button" class="btn btn-primary" onclick="saveConfiguration()">
                                        <i class="bi bi-check-lg"></i> Запази конфигурация
                                    </button>
                                    <span id="saveStatus" class="ms-3 text-muted"></span>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-hdd-network-fill text-muted" style="font-size: 4rem;"></i>
                        <h5 class="mt-3">Изберете машина</h5>
                        <p class="text-muted">Изберете машина от списъка или добавете нова чрез полето "Име на нова машина".</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    async function saveConfiguration() {
        const machineName = document.getElementById('configMachineName').value;
        const vpnProcessNamesRaw = document.getElementById('vpnProcessNames').value;
        const vpnProcessNamesJson = '["' + vpnProcessNamesRaw.split(',').map(s => s.trim()).filter(s => s).join('","') + '"]';

        const config = {
            MachineName: machineName,
            ServiceUrl: document.getElementById('serviceUrl').value.trim(),
            ApiKey: document.getElementById('apiKey').value.trim() || null,
            RequireVpn: document.getElementById('requireVpn').checked,
            VpnCheckInterval: parseInt(document.getElementById('vpnCheckInterval').value) || 300,
            VpnGateways: '[]',
            VpnProcessNames: vpnProcessNamesJson,
            OfflineMode: document.getElementById('offlineMode').checked,
            OfflineDataRetention: parseInt(document.getElementById('offlineDataRetention').value) || 7,
            ConnectionTimeout: parseInt(document.getElementById('connectionTimeout').value) || 30,
            RetryInterval: parseInt(document.getElementById('retryInterval').value) || 60,
            MaxRetries: parseInt(document.getElementById('maxRetries').value) || 3,
            ScreenshotEnabled: document.getElementById('screenshotEnabled').checked,
            ScreenshotIntervalMinutes: parseInt(document.getElementById('screenshotIntervalMinutes').value) || 5
        };

        const statusEl = document.getElementById('saveStatus');
        statusEl.textContent = 'Запазване...';
        statusEl.classList.remove('text-success', 'text-danger');

        try {
            const response = await fetch('/api/monitor/configuration', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(config)
            });

            if (response.ok) {
                statusEl.textContent = 'Запазено успешно!';
                statusEl.classList.add('text-success');
            } else {
                const err = await response.json().catch(() => ({}));
                statusEl.textContent = err.message || 'Грешка при запазване';
                statusEl.classList.add('text-danger');
            }
        } catch (error) {
            statusEl.textContent = 'Грешка: ' + error.message;
            statusEl.classList.add('text-danger');
        }
    }
</script>
}
