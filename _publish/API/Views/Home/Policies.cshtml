@{
    ViewData["Title"] = "Политики за ограничения";
    Layout = "_Layout";
    var policies = ViewBag.Policies as List<ADS.WindowsAuth.Core.Models.Policy> ?? new List<ADS.WindowsAuth.Core.Models.Policy>();
}

<div class="container mt-5 mb-5">
    <!-- Заглавие -->
    <div class="row mb-4">
        <div class="col-md-12 text-center fade-in">
            <h1 class="display-4 mb-3" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-weight: 800;">
                🔒 Политики за ограничения
            </h1>
            <p class="lead text-white" style="text-shadow: 0 2px 4px rgba(0,0,0,0.2);">
                Управление на правила за блокиране на сайтове, приложения и устройства
            </p>
        </div>
    </div>

    <!-- Статистика -->
    <div class="row mb-4 g-3">
        <div class="col-md-4">
            <div class="glass-card text-center scale-in py-3">
                <div style="font-size:2.5rem;">📋</div>
                <div class="fs-2 fw-bold text-white">@policies.Count</div>
                <div class="text-muted small">Общо политики</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-card text-center scale-in py-3" style="animation-delay:0.05s;">
                <div style="font-size:2.5rem;">✅</div>
                <div class="fs-2 fw-bold text-white">@policies.Count(p => p.IsActive)</div>
                <div class="text-muted small">Активни политики</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-card text-center scale-in py-3" style="animation-delay:0.1s;">
                <div style="font-size:2.5rem;">🖥️</div>
                <div class="fs-2 fw-bold text-white">@policies.SelectMany(p => p.TargetMachines).Distinct().Count()</div>
                <div class="text-muted small">Засегнати машини</div>
            </div>
        </div>
    </div>

    <!-- Таблица с политики -->
    <div class="glass-card fade-in" style="animation-delay:0.15s;">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div class="d-flex align-items-center">
                <div style="font-size:2rem; margin-right:1rem;">🛡️</div>
                <div>
                    <h5 class="mb-0">Списък с политики</h5>
                    <small class="text-muted">Кликни на ред за детайли</small>
                </div>
            </div>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#policyModal" id="btnNewPolicy">
                <i class="bi bi-plus-circle"></i> Нова политика
            </button>
        </div>

        @if (policies.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Политика</th>
                            <th>Статус</th>
                            <th class="text-center">🌐 Сайтове</th>
                            <th class="text-center">💻 Приложения</th>
                            <th>🖥️ Машини</th>
                            <th>👤 Потребители</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var policy in policies)
                        {
                            <tr>
                                <td>
                                    <strong>@policy.Name</strong>
                                    @if (!string.IsNullOrEmpty(policy.Description))
                                    {
                                        <br /><small class="text-muted">@policy.Description</small>
                                    }
                                </td>
                                <td>
                                    @if (policy.IsActive)
                                    {
                                        <span class="badge bg-success">✅ Активна</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">⏸ Неактивна</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (policy.BlockedWebsites.Count > 0)
                                    {
                                        <span class="badge bg-danger">@policy.BlockedWebsites.Count</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (policy.BlockedApplications.Count > 0)
                                    {
                                        <span class="badge bg-warning text-dark">@policy.BlockedApplications.Count</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td>
                                    <small>
                                        @if (policy.TargetMachines.Count == 0)
                                        {
                                            <span class="badge bg-info text-dark">Всички</span>
                                        }
                                        else
                                        {
                                            @string.Join(", ", policy.TargetMachines.Take(2))
                                            @if (policy.TargetMachines.Count > 2)
                                            {
                                                <span class="text-muted"> +@(policy.TargetMachines.Count - 2)</span>
                                            }
                                        }
                                    </small>
                                </td>
                                <td>
                                    <small>
                                        @if (policy.TargetUsers.Count == 0)
                                        {
                                            <span class="badge bg-info text-dark">Всички</span>
                                        }
                                        else
                                        {
                                            @string.Join(", ", policy.TargetUsers.Take(2))
                                            @if (policy.TargetUsers.Count > 2)
                                            {
                                                <span class="text-muted"> +@(policy.TargetUsers.Count - 2)</span>
                                            }
                                        }
                                    </small>
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary me-1" onclick="editPolicy(@policy.Id)" title="Редактирай">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" onclick="deletePolicy(@policy.Id, '@policy.Name')" title="Изтрий">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <div style="font-size:4rem; opacity:0.4;">🔒</div>
                <h5 class="text-muted mt-3">Няма създадени политики</h5>
                <p class="text-muted small">Кликнете „Нова политика" за да добавите ограничения</p>
            </div>
        }
    </div>

    <!-- Навигация назад -->
    <div class="glass-card fade-in mt-4" style="animation-delay:0.2s;">
        <a href="/" class="btn btn-outline-primary">
            <i class="bi bi-house"></i> Начало
        </a>
    </div>
</div>

<!-- Modal за създаване/редактиране -->
<div class="modal fade" id="policyModal" tabindex="-1" aria-labelledby="policyModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content" style="background: rgba(30,30,60,0.97); border: 1px solid rgba(255,255,255,0.15); backdrop-filter: blur(20px);">
            <div class="modal-header" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                <h5 class="modal-title text-white" id="policyModalLabel">
                    <span id="modalTitleIcon">➕</span> <span id="policyModalTitle">Нова политика</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="policyForm">
                    <input type="hidden" id="policyId" value="0">

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label text-white">Име на политиката <span class="text-danger">*</span></label>
                            <input type="text" class="form-control bg-transparent text-white border-secondary" id="policyName" placeholder="напр. Блокиране на социални мрежи" required>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="policyIsActive" checked>
                                <label class="form-check-label text-white" for="policyIsActive">Активна</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-white">Описание</label>
                            <textarea class="form-control bg-transparent text-white border-secondary" id="policyDescription" rows="2" placeholder="Кратко описание на политиката..."></textarea>
                        </div>
                    </div>

                    <hr style="border-color: rgba(255,255,255,0.1);" class="my-3">

                    <!-- Табове за Приложения и Уебсайтове -->
                    <ul class="nav nav-tabs mb-3" style="border-color: rgba(255,255,255,0.15);">
                        <li class="nav-item">
                            <button class="nav-link active text-white" id="tabAppsBtn" onclick="switchTab('apps')" type="button" style="background:transparent;border-color:rgba(255,255,255,0.2) rgba(255,255,255,0.2) transparent;">
                                💻 Приложения
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link text-secondary" id="tabWebBtn" onclick="switchTab('web')" type="button" style="background:transparent;border-color:transparent;">
                                🌐 Уебсайтове
                            </button>
                        </li>
                    </ul>

                    <!-- Таб: Приложения -->
                    <div id="tabApps">
                        <div class="row g-2 mb-2">
                            <div class="col-12">
                                <div class="btn-group btn-group-sm w-100" role="group">
                                    <input type="radio" class="btn-check" name="appMode" id="appModeBlacklist" value="blacklist" checked>
                                    <label class="btn btn-outline-danger" for="appModeBlacklist">🚫 Черен списък (блокирай тези)</label>
                                    <input type="radio" class="btn-check" name="appMode" id="appModeWhitelist" value="whitelist">
                                    <label class="btn btn-outline-success" for="appModeWhitelist">✅ Бял списък (само тези са позволени)</label>
                                </div>
                            </div>
                        </div>
                        <div id="appBlacklistSection">
                            <label class="form-label text-white">Блокирани приложения</label>
                            <textarea class="form-control bg-transparent text-white border-secondary font-monospace" id="blockedApplications" rows="5"
                                      placeholder="chrome.exe&#10;firefox.exe&#10;steam.exe&#10;sapgui.exe"></textarea>
                            <small class="text-muted">По едно на ред – процесно име (без пътя)</small>
                        </div>
                        <div id="appWhitelistSection" style="display:none;">
                            <label class="form-label text-white">Разрешени приложения (само тези могат да работят)</label>
                            <textarea class="form-control bg-transparent text-white border-secondary font-monospace" id="allowedApplications" rows="5"
                                      placeholder="sapgui.exe&#10;excel.exe&#10;winword.exe&#10;outlook.exe"></textarea>
                            <small class="text-muted">Всичко друго ще бъде спряно автоматично</small>
                        </div>
                    </div>

                    <!-- Таб: Уебсайтове -->
                    <div id="tabWeb" style="display:none;">
                        <div class="row g-2 mb-2">
                            <div class="col-12">
                                <div class="btn-group btn-group-sm w-100" role="group">
                                    <input type="radio" class="btn-check" name="webMode" id="webModeBlacklist" value="blacklist" checked>
                                    <label class="btn btn-outline-danger" for="webModeBlacklist">🚫 Черен списък (блокирай тези)</label>
                                    <input type="radio" class="btn-check" name="webMode" id="webModeWhitelist" value="whitelist">
                                    <label class="btn btn-outline-success" for="webModeWhitelist">✅ Бял списък (само тези са позволени)</label>
                                </div>
                            </div>
                        </div>
                        <div id="webBlacklistSection">
                            <label class="form-label text-white">Блокирани уебсайтове</label>
                            <textarea class="form-control bg-transparent text-white border-secondary font-monospace" id="blockedWebsites" rows="5"
                                      placeholder="facebook.com&#10;twitter.com&#10;instagram.com&#10;youtube.com"></textarea>
                            <small class="text-muted">По един домейн на ред</small>
                        </div>
                        <div id="webWhitelistSection" style="display:none;">
                            <label class="form-label text-white">Разрешени уебсайтове (само тези могат да се отварят)</label>
                            <textarea class="form-control bg-transparent text-white border-secondary font-monospace" id="allowedWebsites" rows="5"
                                      placeholder="company-erp.com&#10;sap-system.local&#10;office.com"></textarea>
                            <small class="text-muted">Всичко останало ще бъде блокирано</small>
                        </div>
                    </div>

                    <hr style="border-color: rgba(255,255,255,0.1);" class="my-3">

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-white">🖥️ Целеви машини</label>
                            <textarea class="form-control bg-transparent text-white border-secondary font-monospace" id="targetMachines" rows="3"
                                      placeholder="PC-001&#10;PC-002"></textarea>
                            <small class="text-muted">Оставете празно = всички машини</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-white">👤 Целеви потребители</label>
                            <textarea class="form-control bg-transparent text-white border-secondary font-monospace" id="targetUsers" rows="3"
                                      placeholder="ivan.petrov&#10;maria.georgieva"></textarea>
                            <small class="text-muted">Оставете празно = всички потребители</small>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer" style="border-top: 1px solid rgba(255,255,255,0.1);">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Отказ</button>
                <button type="button" class="btn btn-primary" onclick="savePolicy()">
                    <i class="bi bi-check-circle"></i> <span id="saveBtnText">Създай политика</span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Toast за уведомления -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1100">
    <div id="policyToast" class="toast align-items-center text-white border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body" id="toastMessage">Политиката е запазена.</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const policyModal = new bootstrap.Modal(document.getElementById('policyModal'));
    const toast = new bootstrap.Toast(document.getElementById('policyToast'));

    function switchTab(tab) {
        document.getElementById('tabApps').style.display = tab === 'apps' ? '' : 'none';
        document.getElementById('tabWeb').style.display = tab === 'web' ? '' : 'none';
        document.getElementById('tabAppsBtn').className = `nav-link ${tab === 'apps' ? 'active text-white' : 'text-secondary'}`;
        document.getElementById('tabWebBtn').className = `nav-link ${tab === 'web' ? 'active text-white' : 'text-secondary'}`;
        document.getElementById('tabAppsBtn').style.cssText = tab === 'apps' ? 'background:transparent;border-color:rgba(255,255,255,0.2) rgba(255,255,255,0.2) transparent;' : 'background:transparent;border-color:transparent;';
        document.getElementById('tabWebBtn').style.cssText = tab === 'web' ? 'background:transparent;border-color:rgba(255,255,255,0.2) rgba(255,255,255,0.2) transparent;' : 'background:transparent;border-color:transparent;';
    }

    document.getElementById('appModeBlacklist').addEventListener('change', () => {
        document.getElementById('appBlacklistSection').style.display = '';
        document.getElementById('appWhitelistSection').style.display = 'none';
    });
    document.getElementById('appModeWhitelist').addEventListener('change', () => {
        document.getElementById('appBlacklistSection').style.display = 'none';
        document.getElementById('appWhitelistSection').style.display = '';
    });
    document.getElementById('webModeBlacklist').addEventListener('change', () => {
        document.getElementById('webBlacklistSection').style.display = '';
        document.getElementById('webWhitelistSection').style.display = 'none';
    });
    document.getElementById('webModeWhitelist').addEventListener('change', () => {
        document.getElementById('webBlacklistSection').style.display = 'none';
        document.getElementById('webWhitelistSection').style.display = '';
    });

    function showToast(msg, success = true) {
        const el = document.getElementById('policyToast');
        el.className = `toast align-items-center text-white border-0 ${success ? 'bg-success' : 'bg-danger'}`;
        document.getElementById('toastMessage').textContent = msg;
        toast.show();
    }

    // Нула форма при отваряне на нова политика
    document.getElementById('btnNewPolicy').addEventListener('click', () => {
        document.getElementById('policyForm').reset();
        document.getElementById('policyId').value = '0';
        document.getElementById('policyModalTitle').textContent = 'Нова политика';
        document.getElementById('modalTitleIcon').textContent = '➕';
        document.getElementById('saveBtnText').textContent = 'Създай политика';
        document.getElementById('policyIsActive').checked = true;
    });

    async function savePolicy() {
        const name = document.getElementById('policyName').value.trim();
        if (!name) {
            document.getElementById('policyName').focus();
            showToast('Моля, въведете име на политиката', false);
            return;
        }

        const id = parseInt(document.getElementById('policyId').value) || 0;
        const appMode = document.querySelector('input[name="appMode"]:checked').value;
        const webMode = document.querySelector('input[name="webMode"]:checked').value;
        const policy = {
            Id: id,
            Name: name,
            Description: document.getElementById('policyDescription').value,
            IsActive: document.getElementById('policyIsActive').checked,
            BlockedWebsites: webMode === 'blacklist' ? document.getElementById('blockedWebsites').value.split('\n').map(s => s.trim()).filter(Boolean) : [],
            AllowedWebsites: webMode === 'whitelist' ? document.getElementById('allowedWebsites').value.split('\n').map(s => s.trim()).filter(Boolean) : [],
            WebWhitelistMode: webMode === 'whitelist',
            BlockedApplications: appMode === 'blacklist' ? document.getElementById('blockedApplications').value.split('\n').map(s => s.trim()).filter(Boolean) : [],
            AllowedApplications: appMode === 'whitelist' ? document.getElementById('allowedApplications').value.split('\n').map(s => s.trim()).filter(Boolean) : [],
            AppWhitelistMode: appMode === 'whitelist',
            TargetMachines: document.getElementById('targetMachines').value.split('\n').map(s => s.trim()).filter(Boolean),
            TargetUsers: document.getElementById('targetUsers').value.split('\n').map(s => s.trim()).filter(Boolean),
            BlockedFileExtensions: [],
            AllowedInstallations: [],
            BlockedInstallations: [],
            MaxScreenTimeSeconds: 0,
            BlockUsbAccess: false,
            BlockPrinterAccess: false,
            BlockBluetoothAccess: false
        };

        const url = id > 0 ? `/api/Policy/${id}` : '/api/Policy';
        const method = id > 0 ? 'PUT' : 'POST';

        try {
            const resp = await fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(policy)
            });

            if (resp.ok) {
                policyModal.hide();
                showToast(id > 0 ? 'Политиката е обновена.' : 'Политиката е създадена.');
                setTimeout(() => location.reload(), 800);
            } else {
                const err = await resp.json().catch(() => ({ message: resp.statusText }));
                showToast('Грешка: ' + (err.message || resp.statusText), false);
            }
        } catch (e) {
            showToast('Мрежова грешка: ' + e.message, false);
        }
    }

    async function editPolicy(id) {
        try {
            const resp = await fetch(`/api/Policy/${id}`);
            if (!resp.ok) throw new Error('Грешка при зареждане');
            const p = await resp.json();

            document.getElementById('policyId').value = p.id;
            document.getElementById('policyName').value = p.name;
            document.getElementById('policyDescription').value = p.description || '';
            document.getElementById('policyIsActive').checked = p.isActive;
            // Приложения
            if (p.appWhitelistMode) {
                document.getElementById('appModeWhitelist').checked = true;
                document.getElementById('appBlacklistSection').style.display = 'none';
                document.getElementById('appWhitelistSection').style.display = '';
                document.getElementById('allowedApplications').value = (p.allowedApplications || []).join('\n');
                document.getElementById('blockedApplications').value = '';
            } else {
                document.getElementById('appModeBlacklist').checked = true;
                document.getElementById('appBlacklistSection').style.display = '';
                document.getElementById('appWhitelistSection').style.display = 'none';
                document.getElementById('blockedApplications').value = (p.blockedApplications || []).join('\n');
                document.getElementById('allowedApplications').value = '';
            }
            // Уебсайтове
            if (p.webWhitelistMode) {
                document.getElementById('webModeWhitelist').checked = true;
                document.getElementById('webBlacklistSection').style.display = 'none';
                document.getElementById('webWhitelistSection').style.display = '';
                document.getElementById('allowedWebsites').value = (p.allowedWebsites || []).join('\n');
                document.getElementById('blockedWebsites').value = '';
            } else {
                document.getElementById('webModeBlacklist').checked = true;
                document.getElementById('webBlacklistSection').style.display = '';
                document.getElementById('webWhitelistSection').style.display = 'none';
                document.getElementById('blockedWebsites').value = (p.blockedWebsites || []).join('\n');
                document.getElementById('allowedWebsites').value = '';
            }
            document.getElementById('targetMachines').value = (p.targetMachines || []).join('\n');
            document.getElementById('targetUsers').value = (p.targetUsers || []).join('\n');

            document.getElementById('policyModalTitle').textContent = 'Редактирай: ' + p.name;
            document.getElementById('modalTitleIcon').textContent = '✏️';
            document.getElementById('saveBtnText').textContent = 'Запази промените';

            policyModal.show();
        } catch (e) {
            showToast('Грешка при зареждане: ' + e.message, false);
        }
    }

    async function deletePolicy(id, name) {
        if (!confirm(`Изтриване на политика „${name}"?\n\nТова действие е необратимо.`)) return;

        try {
            const resp = await fetch(`/api/Policy/${id}`, { method: 'DELETE', credentials: 'same-origin' });
            if (resp.ok) {
                showToast('Политиката е изтрита.');
                setTimeout(() => location.reload(), 800);
            } else {
                let errText = 'Грешка при изтриване';
                try {
                    const bodyText = await resp.text();
                    try {
                        const data = JSON.parse(bodyText);
                        if (data.error) errText = data.error;
                        else if (data.message) errText = data.message;
                    } catch (_) { if (bodyText) errText = bodyText; }
                } catch (_) {}
                showToast(errText, false);
            }
        } catch (e) {
            showToast('Мрежова грешка: ' + e.message, false);
        }
    }
</script>
}
