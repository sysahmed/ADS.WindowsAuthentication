@{
    Layout = "_Layout";
    ViewData["Title"] = "Системни логове";
    var machines = ViewBag.Machines as List<string> ?? new List<string>();
    var sources = ViewBag.Sources as List<string> ?? new List<string>();
    var machineName = ViewBag.MachineName as string;
    var level = ViewBag.Level as string;
    var source = ViewBag.Source as string;
    var logs = ViewBag.Logs as List<ADS.WindowsAuth.Core.Data.Entities.LogEntryEntity> ?? new List<ADS.WindowsAuth.Core.Data.Entities.LogEntryEntity>();
    var levelStats = ViewBag.LevelStats as List<ADS.WindowsAuth.API.Controllers.LevelStat> ?? new List<ADS.WindowsAuth.API.Controllers.LevelStat>();
    var page = ViewBag.Page as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
    string Qs(string? m, string? l, string? s, int p)
    {
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(m)) parts.Add($"machineName={Uri.EscapeDataString(m)}");
        if (!string.IsNullOrEmpty(l)) parts.Add($"level={Uri.EscapeDataString(l)}");
        if (!string.IsNullOrEmpty(s)) parts.Add($"source={Uri.EscapeDataString(s)}");
        if (p > 1) parts.Add($"page={p}");
        return parts.Count > 0 ? "?" + string.Join("&", parts) : "";
    }
}

<div class="container mt-4 mb-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2 class="mb-2">📝 Системни логове</h2>
            <p class="text-muted mb-0">Централизиран преглед на логове от API, Monitor и Client.</p>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-primary">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <h5 class="mb-0"><i class="bi bi-file-text"></i> Логове на API сървъра (файл)</h5>
                    <button type="button" class="btn btn-light btn-sm" id="btnRefreshServerLogs" title="Обнови">
                        <i class="bi bi-arrow-clockwise"></i> Обнови
                    </button>
                </div>
                <div class="card-body p-2">
                    <p class="text-muted small mb-2">
                        Последните редове от лог файла на този сървър (Serilog). При хостиране тук виждате същите редове, които се записват в папка <code>logs/</code> на приложението.
                    </p>
                    <pre id="serverLogContent" class="bg-dark text-light p-3 rounded small mb-0" style="max-height: 400px; overflow: auto; font-size: 0.8rem; white-space: pre-wrap; word-break: break-all;">Зареждане...</pre>
                    <div id="serverLogMeta" class="small text-muted mt-1"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-12">
                <div class="d-flex flex-wrap gap-2">
                <a href="/" class="btn btn-outline-primary btn-sm"><i class="bi bi-house"></i> Начало</a>
                <a href="/login-events" class="btn btn-outline-primary btn-sm"><i class="bi bi-box-arrow-in-right"></i> Windows влизания</a>
                <a href="/monitor" class="btn btn-outline-primary btn-sm"><i class="bi bi-pc-display"></i> Монитор</a>
                <a href="/policies" class="btn btn-outline-primary btn-sm"><i class="bi bi-shield-lock"></i> Политики</a>
                <a href="/monitor-settings" class="btn btn-outline-secondary btn-sm"><i class="bi bi-gear"></i> Настройки</a>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0">Филтри</h5>
                </div>
                <div class="card-body">
                    <form method="get" action="/system-logs">
                        <div class="mb-3">
                            <label for="machineName" class="form-label">Машина:</label>
                            <select class="form-select" id="machineName" name="machineName">
                                <option value="">-- Всички машини --</option>
                                @foreach (var m in machines)
                                {
                                    if (m == machineName)
                                    {
                                        <option value="@m" selected>@m</option>
                                    }
                                    else
                                    {
                                        <option value="@m">@m</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="source" class="form-label">Източник:</label>
                            <select class="form-select" id="source" name="source">
                                <option value="">-- Всички източници --</option>
                                @foreach (var s in sources)
                                {
                                    if (s == source)
                                    {
                                        <option value="@s" selected>@s</option>
                                    }
                                    else
                                    {
                                        <option value="@s">@s</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="level" class="form-label">Ниво:</label>
                            <select class="form-select" id="level" name="level">
                                <option value="">-- Всички нива --</option>
                                @if (level == "DEBUG") { <option value="DEBUG" selected>DEBUG</option> } else { <option value="DEBUG">DEBUG</option> }
                                @if (level == "INFO") { <option value="INFO" selected>INFO</option> } else { <option value="INFO">INFO</option> }
                                @if (level == "WARNING") { <option value="WARNING" selected>WARNING</option> } else { <option value="WARNING">WARNING</option> }
                                @if (level == "ERROR") { <option value="ERROR" selected>ERROR</option> } else { <option value="ERROR">ERROR</option> }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Приложи филтри</button>
                        <a href="/system-logs" class="btn btn-secondary w-100 mt-2">Изчисти</a>
                    </form>
                </div>
            </div>

            @if (levelStats.Any())
            {
                <div class="card mt-3 shadow-sm">
                    <div class="card-header">
                        <h5 class="mb-0">Статистика</h5>
                    </div>
                    <div class="card-body">
                        @foreach (var stat in levelStats)
                        {
                            <div class="d-flex justify-content-between mb-2">
                                <span>@stat.Level:</span>
                                <strong>@stat.Count</strong>
                            </div>
                        }
                        <hr>
                        <div class="d-flex justify-content-between">
                            <strong>Общо:</strong>
                            <strong>@totalCount</strong>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="col-md-9">
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <h5 class="mb-0">Логове @(string.IsNullOrEmpty(machineName) ? "" : $"за {machineName}")@(string.IsNullOrEmpty(source) ? "" : $" ({source})")</h5>
                    <div class="d-flex align-items-center gap-2">
                        @if (!string.IsNullOrEmpty(machineName))
                        {
                            <a href="/machine/@machineName" class="btn btn-sm btn-info">
                                <i class="bi bi-cpu"></i> Процеси
                            </a>
                            <button class="btn btn-sm btn-success" id="btnRemoteDesktop" onclick="connectRemoteDesktop('@machineName')">
                                <i class="bi bi-display"></i> Remote Desktop
                            </button>
                        }
                        <span class="badge bg-secondary">@totalCount общо</span>
                    </div>
                </div>
                <div class="card-body">
                    @if (logs.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead>
                                    <tr>
                                        <th style="width: 32px;"></th>
                                        <th>Време</th>
                                        <th>Ниво</th>
                                        <th>Машина</th>
                                        <th>Потребител</th>
                                        <th>Източник</th>
                                        <th>Съобщение</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var log in logs)
                                    {
                                        var lvl = log?.Level ?? "INFO";
                                        var hasDetails = !string.IsNullOrEmpty(log?.Message) && log.Message.Length > 80
                                            || !string.IsNullOrEmpty(log?.StackTrace);
                                        <tr class="log-entry log-@lvl log-row @(hasDetails ? "clickable" : "")" data-log-id="log-@log?.Id"
                                            @if (hasDetails) { <text> style="cursor: pointer;" </text> }>
                                            <td class="text-muted">
                                                @if (hasDetails)
                                                {
                                                    <span class="expand-icon">▶</span>
                                                }
                                            </td>
                                            <td>@(log?.Timestamp.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                                            <td>
                                                <span class="badge @(lvl == "ERROR" ? "bg-danger" : lvl == "WARNING" ? "bg-warning text-dark" : lvl == "DEBUG" ? "bg-secondary" : "bg-info") badge-level">
                                                    @lvl
                                                </span>
                                            </td>
                                            <td>@(log?.MachineName ?? "-")</td>
                                            <td>@(string.IsNullOrEmpty(log?.Username) && string.IsNullOrEmpty(log?.Domain) ? "-" : $"{log?.Username ?? "-"}@{log?.Domain ?? "-"}")</td>
                                            <td>@(log?.Source ?? "-")</td>
                                            <td>
                                                <div class="log-message-preview" style="max-width: 350px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@(log?.Message ?? "")">
                                                    @(log?.Message ?? "-")
                                                </div>
                                                @if (!string.IsNullOrEmpty(log?.ExceptionType))
                                                {
                                                    <small class="text-danger d-block">@log.ExceptionType</small>
                                                }
                                            </td>
                                        </tr>
                                        @if (hasDetails)
                                        {
                                            <tr class="log-detail" id="detail-log-@log?.Id" style="display: none;">
                                                <td colspan="7" class="bg-light small p-3">
                                                    <div class="mb-2"><strong>Пълно съобщение:</strong></div>
                                                    <pre class="mb-0" style="white-space: pre-wrap; word-break: break-word; font-size: 0.85em;">@(log?.Message ?? "-")</pre>
                                                    @if (!string.IsNullOrEmpty(log?.StackTrace))
                                                    {
                                                        <div class="mt-3"><strong>Stack trace:</strong></div>
                                                        <pre class="mb-0 text-danger" style="white-space: pre-wrap; word-break: break-word; font-size: 0.8em;">@log.StackTrace</pre>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (totalPages > 1)
                        {
                            <nav class="mt-3">
                                <ul class="pagination justify-content-center mb-0">
                                    @if (page > 1)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="/system-logs@(Qs(machineName, level, source, page - 1))">Предишна</a>
                                        </li>
                                    }
                                    @for (int i = Math.Max(1, page - 2); i <= Math.Min(totalPages, page + 2); i++)
                                    {
                                        <li class="page-item @(i == page ? "active" : "")">
                                            <a class="page-link" href="/system-logs@(Qs(machineName, level, source, i))">@i</a>
                                        </li>
                                    }
                                    @if (page < totalPages)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="/system-logs@(Qs(machineName, level, source, page + 1))">Следваща</a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            Няма намерени логове с избраните филтри.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .log-entry.log-ERROR { background-color: #fee; border-left: 4px solid #dc3545; }
    .log-entry.log-WARNING { background-color: #fff3cd; border-left: 4px solid #ffc107; }
    .log-entry.log-INFO { background-color: #d1ecf1; border-left: 4px solid #17a2b8; }
    .log-entry.log-DEBUG { background-color: #e9ecef; border-left: 4px solid #6c757d; }
    .badge-level { font-size: 0.75em; padding: 0.25em 0.5em; }
    .log-row.clickable:hover { background-color: rgba(0,0,0,0.03) !important; }
    .log-row.expanded .expand-icon { transform: rotate(90deg); }
</style>

@section Scripts {
<script>
(function() {
    var pre = document.getElementById('serverLogContent');
    var meta = document.getElementById('serverLogMeta');
    var btn = document.getElementById('btnRefreshServerLogs');

    function loadServerLogs() {
        if (pre) pre.textContent = 'Зареждане...';
        if (meta) meta.textContent = '';
        fetch('/api/logs/server-file?maxLines=1500', { credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (pre) {
                    pre.textContent = data.content || data.warning || data.error || '(празно)';
                }
                if (meta) {
                    var parts = [];
                    if (data.fileName) parts.push('Файл: ' + data.fileName);
                    if (data.warning) parts.push(data.warning);
                    if (data.error) parts.push('Грешка: ' + data.error);
                    meta.textContent = parts.join(' · ');
                }
            })
            .catch(function(e) {
                if (pre) pre.textContent = 'Грешка при зареждане: ' + e.message;
            });
    }

    if (btn) btn.addEventListener('click', loadServerLogs);
    loadServerLogs();
})();

async function connectRemoteDesktop(machineName) {
    const btn = document.getElementById('btnRemoteDesktop');
    if (!btn) return;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Свързване...';

    try {
        const resp = await fetch('/api/remotedesktop/sessions/createorget', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ machineName: machineName, requestedBy: 'web-admin' })
        });

        if (!resp.ok) throw new Error('API грешка: ' + resp.status);

        const data = await resp.json();
        window.location.href = '/RemoteDesktop/Viewer?sessionId=' + data.sessionId;
    } catch (err) {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-display"></i> Remote Desktop';
        alert('Грешка при свързване: ' + err.message);
    }
}

document.querySelectorAll('.log-row.clickable').forEach(function(row) {
    row.addEventListener('click', function(e) {
        if (e.target.tagName === 'A') return;
        var id = row.getAttribute('data-log-id');
        var detail = document.getElementById('detail-' + id);
        if (!detail) detail = document.getElementById(id);
        if (!detail) return;
        var isHidden = detail.style.display === 'none';
        detail.style.display = isHidden ? 'table-row' : 'none';
        row.classList.toggle('expanded', isHidden);
    });
});
</script>
}
