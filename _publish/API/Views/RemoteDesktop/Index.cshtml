@{
    ViewData["Title"] = "Remote Desktop - Машини";
    var monitoredMachines = ViewBag.MonitoredMachines as List<string> ?? new List<string>();
}

<div class="container mt-4 mb-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2 class="mb-1">🖥️ Remote Desktop</h2>
            <p class="text-muted mb-0">Свържи се към наблюдавани машини или към активна сесия.</p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-12">
            <div class="d-flex flex-wrap gap-2">
                <a href="/" class="btn btn-outline-primary btn-sm"><i class="bi bi-house"></i> Начало</a>
                <a href="/system-logs" class="btn btn-outline-primary btn-sm"><i class="bi bi-journal-text"></i> Логове</a>
                <a href="/policies" class="btn btn-outline-primary btn-sm"><i class="bi bi-shield-lock"></i> Политики</a>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Monitored machines -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-pc-display"></i> Наблюдавани машини</h5>
                    <span class="badge bg-secondary">@monitoredMachines.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (monitoredMachines.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var machine in monitoredMachines)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span><i class="bi bi-display text-primary me-2"></i>@machine</span>
                                    <button class="btn btn-sm btn-success" onclick="connectToMachine('@machine')">
                                        <i class="bi bi-plug"></i> Свържи се
                                    </button>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted">
                            <i class="bi bi-pc-display" style="font-size:2rem;"></i>
                            <p class="mt-2 mb-0">Няма наблюдавани машини от последните 7 дни.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Active sessions -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-broadcast"></i> Активни RD сесии</h5>
                    <div class="d-flex align-items-center gap-2">
                        <div class="spinner-border spinner-border-sm text-primary" id="refreshSpinner" style="display:none;"></div>
                        <small class="text-muted">5s refresh</small>
                    </div>
                </div>
                <div class="card-body p-0" id="sessionsContainer">
                    <div class="p-4 text-center">
                        <div class="spinner-border text-primary"></div>
                        <p class="text-muted mt-2 mb-0">Зареждане...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Connect with Session ID -->
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-body d-flex align-items-center gap-3 flex-wrap">
                    <i class="bi bi-box-arrow-in-right" style="font-size:1.5rem; color:#667eea;"></i>
                    <div>
                        <strong>Имаш Session ID?</strong>
                        <span class="text-muted ms-2">Свържи се директно към машина с известен ID.</span>
                    </div>
                    <a href="@Url.Action("Connect")" class="btn btn-primary ms-auto">
                        <i class="bi bi-plug"></i> Свържи се с Session ID
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script src="/js/remote-desktop.js"></script>
<script>
    initRemoteDesktop('');

    const originalLoad = window.loadActiveSessions;
    if (originalLoad) {
        window.loadActiveSessions = async function() {
            const spinner = document.getElementById('refreshSpinner');
            if (spinner) spinner.style.display = 'inline-block';
            await originalLoad();
            if (spinner) spinner.style.display = 'none';
        };
    }

    async function connectToMachine(machineName) {
        try {
            const resp = await fetch('/api/remotedesktop/sessions/createorget', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ machineName: machineName, requestedBy: 'web-admin' })
            });
            if (!resp.ok) throw new Error('HTTP ' + resp.status);
            const data = await resp.json();
            window.location.href = '/RemoteDesktop/Viewer?sessionId=' + data.sessionId;
        } catch (err) {
            alert('Грешка при свързване с ' + machineName + ': ' + err.message);
        }
    }
</script>
}
