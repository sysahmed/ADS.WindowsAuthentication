@{
    ViewData["Title"] = "Remote Desktop Viewer";
    var sessionId = ViewData["SessionId"] as string;
    var serviceUrl = ViewData["HubUrl"] as string ?? "/hubs/remotedesktop";
}

<style>
    body {
        overflow: hidden;
    }
    
    #viewerContainer {
        position: fixed;
        top: 60px;
        left: 0;
        right: 0;
        bottom: 0;
        background: #1a1a1a;
        display: flex;
        flex-direction: column;
    }

    #toolbar {
        background: #2d2d2d;
        color: white;
        padding: 10px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid #404040;
    }

    #screenContainer {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: auto;
        position: relative;
    }

    #remoteScreen {
        max-width: 100%;
        max-height: 100%;
        box-shadow: 0 0 30px rgba(0,0,0,0.5);
        cursor: crosshair;
    }

    #statusPanel {
        background: rgba(0,0,0,0.8);
        color: white;
        padding: 20px;
        border-radius: 8px;
        text-align: center;
    }

    .status-connecting { color: #ffc107; }
    .status-connected { color: #28a745; }
    .status-error { color: #dc3545; }

    #stats {
        font-size: 0.85em;
        opacity: 0.7;
    }
</style>

<div id="viewerContainer">
    <div id="toolbar">
        <div>
            <strong>Session:</strong> <code>@sessionId</code>
            <span id="connectionStatus" class="ms-3 status-connecting">● Свързване...</span>
        </div>
        <div id="stats">
            FPS: <span id="fpsCounter">0</span> | 
            Frames: <span id="frameCounter">0</span>
        </div>
        <div>
            <button class="btn btn-sm btn-warning" id="btnRequestControl" disabled>
                <i class="bi bi-unlock"></i> Заяви Контрол
            </button>
            <button class="btn btn-sm btn-danger" id="btnDisconnect">
                <i class="bi bi-x-circle"></i> Изключи
            </button>
        </div>
    </div>

    <div id="screenContainer">
        <div id="statusPanel">
            <div class="spinner-border status-connecting" role="status">
                <span class="visually-hidden">Свързване...</span>
            </div>
            <p class="mt-3" id="statusMessage">Свързване към host...</p>
        </div>
        <img id="remoteScreen" style="display: none;" alt="Remote Screen">
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    const sessionId = '@sessionId';
    const serviceUrl = '@serviceUrl';
    let connection = null;
    let controlEnabled = false;
    let frameCount = 0;
    let lastFpsUpdate = Date.now();
    let fps = 0;
    let retryTimer = null;
    let waitingForHost = false;
    let _requestingControl = false;

    // Throttle helper – не изпраща по-бързо от веднъж на `ms` милисекунди
    function throttle(fn, ms) {
        let last = 0;
        return function(...args) {
            const now = Date.now();
            if (now - last >= ms) { last = now; fn(...args); }
        };
    }

    async function connectToRemoteDesktop() {
        try {
            connection = new signalR.HubConnectionBuilder()
                .withUrl(serviceUrl)
                .withAutomaticReconnect()
                .build();

            connection.on("ControlGranted", () => {
                controlEnabled = true;
                waitingForHost = false;
                if (retryTimer) { clearInterval(retryTimer); retryTimer = null; }
                updateStatus("Контрол ОДОБРЕН", "connected");
                document.getElementById('btnRequestControl').disabled = true;
                document.getElementById('btnRequestControl').className = 'btn btn-sm btn-success';
                document.getElementById('btnRequestControl').innerHTML = '<i class="bi bi-check-circle"></i> Контрол Активен';
            });

            connection.on("ControlDenied", (reason) => {
                if (reason === "Host не е свързан") {
                    waitingForHost = true;
                    updateStatus("Изчакване на host...", "connecting");
                    document.getElementById('statusMessage').innerHTML =
                        '⏳ Host машината все още не е свързана.<br>' +
                        '<small class="text-muted">Monitor трябва да стартира RemoteDesktopHost.exe.<br>Retry автоматично на всеки 5 секунди...</small>';
                    if (!retryTimer) {
                        let attempt = 0;
                        retryTimer = setInterval(async () => {
                            attempt++;
                            updateStatus(`Опит ${attempt} – чакане на host...`, "connecting");
                            try { await connection.invoke("RequestControl", sessionId, "web-viewer"); } catch {}
                        }, 5000);
                    }
                } else {
                    if (retryTimer) { clearInterval(retryTimer); retryTimer = null; }
                    updateStatus(`Отказан: ${reason}`, "error");
                    document.getElementById('statusMessage').textContent = `Контрол отказан: ${reason}`;
                }
            });

            connection.on("ReceiveFrame", async (frameData) => {
                if (waitingForHost) {
                    waitingForHost = false;
                    if (retryTimer) { clearInterval(retryTimer); retryTimer = null; }
                    updateStatus("Получаване на кадри...", "connected");
                }
                // Ако получаваме кадри но нямаме контрол – заявяваме ВЕДНЪЖ
                if (!controlEnabled && !_requestingControl) {
                    _requestingControl = true;
                    try { await connection.invoke("RequestControl", sessionId, "web-viewer"); } catch {}
                    setTimeout(() => { _requestingControl = false; }, 3000); // retry след 3 сек ако ControlGranted не пристигна
                }
                const img = document.getElementById('remoteScreen');

                // SignalR JSON протокол изпраща byte[] като base64 string
                let bytes;
                if (typeof frameData === 'string') {
                    const bin = atob(frameData);
                    bytes = new Uint8Array(bin.length);
                    for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
                } else {
                    bytes = new Uint8Array(frameData);
                }

                const blob = new Blob([bytes], { type: 'image/jpeg' });
                const url = URL.createObjectURL(blob);
                img.onload = () => URL.revokeObjectURL(url);
                img.src = url;
                img.style.display = 'block';
                document.getElementById('statusPanel').style.display = 'none';
                frameCount++;
                updateFPS();
            });

            connection.on("SessionEnded", () => {
                if (retryTimer) clearInterval(retryTimer);
                updateStatus("Сесията приключи", "error");
                setTimeout(() => window.location.href = '/RemoteDesktop', 2000);
            });

            connection.on("HostDisconnected", () => {
                updateStatus("Host се изключи – изчакване...", "connecting");
                waitingForHost = true;
                document.getElementById('remoteScreen').style.display = 'none';
                document.getElementById('statusPanel').style.display = '';
                document.getElementById('statusMessage').textContent = 'Host се изключи. Изчакване на повторно свързване...';
                if (!retryTimer) {
                    retryTimer = setInterval(async () => {
                        try { await connection.invoke("RequestControl", sessionId, "web-viewer"); } catch {}
                    }, 5000);
                }
            });

            connection.on("Error", (message) => {
                updateStatus(`Грешка: ${message}`, "error");
            });

            connection.on("ReceiveClipboard", async (text) => {
                try {
                    await navigator.clipboard.writeText(text);
                    showClipboardToast('📋 Копирано от remote');
                } catch {}
            });

            await connection.start();
            updateStatus("Свързан! Заявяване на достъп...", "connecting");
            await connection.invoke("RequestControl", sessionId, "web-viewer");
            document.getElementById('btnRequestControl').disabled = false;

        } catch (error) {
            console.error('Connection error:', error);
            updateStatus(`Грешка при свързване: ${error.message}`, "error");
            document.getElementById('statusMessage').textContent = `Грешка: ${error.message}`;
        }
    }

    // Mouse/Keyboard input handlers – проверката за разрешение е в Hub-а (CanControl)
    // Throttle до 20 пъти/сек (50ms) за да не задръстваме SignalR connection-а
    const sendMouseMove = throttle(async (x, y) => {
        if (!connection || connection.state !== 'Connected') return;
        try { await connection.invoke("SendMouseMove", sessionId, x, y); } catch {}
    }, 50);

    document.getElementById('remoteScreen').addEventListener('mousemove', (e) => {
        if (!connection || connection.state !== 'Connected') return;

        const rect = e.target.getBoundingClientRect();
        const scaleX = e.target.naturalWidth / rect.width || 1;
        const scaleY = e.target.naturalHeight / rect.height || 1;

        const x = Math.floor((e.clientX - rect.left) * scaleX);
        const y = Math.floor((e.clientY - rect.top) * scaleY);

        sendMouseMove(x, y);
    });

    document.getElementById('remoteScreen').addEventListener('click', async (e) => {
        if (!connection || connection.state !== 'Connected') return;
        e.preventDefault();
        try { await connection.invoke("SendMouseClick", sessionId, "left"); } catch {}
    });

    document.getElementById('remoteScreen').addEventListener('contextmenu', async (e) => {
        if (!connection || connection.state !== 'Connected') return;
        e.preventDefault();
        try { await connection.invoke("SendMouseClick", sessionId, "right"); } catch {}
    });

    document.getElementById('remoteScreen').addEventListener('wheel', async (e) => {
        if (!connection || connection.state !== 'Connected') return;
        e.preventDefault();
        const delta = e.deltaY > 0 ? 1 : -1;
        try { await connection.invoke("SendMouseScroll", sessionId, delta); } catch {}
    }, { passive: false });

    document.addEventListener('keydown', async (e) => {
        if (!connection || connection.state !== 'Connected') return;
        // Не изпращаме клавиши ако remote screen не е видим
        if (document.getElementById('remoteScreen').style.display === 'none') return;

        // Ctrl+V → изпращаме clipboard текст към host
        if (e.ctrlKey && e.key === 'v') {
            e.preventDefault();
            try {
                const text = await navigator.clipboard.readText();
                if (text) await connection.invoke("SendClipboardToHost", sessionId, text);
            } catch {}
            return;
        }

        e.preventDefault();
        try { await connection.invoke("SendKeyPress", sessionId, e.key); } catch {}
    });

    function showClipboardToast(msg) {
        let t = document.getElementById('clipboardToast');
        if (!t) {
            t = document.createElement('div');
            t.id = 'clipboardToast';
            t.style.cssText = 'position:fixed;bottom:20px;right:20px;background:#333;color:#fff;padding:8px 16px;border-radius:6px;z-index:9999;font-size:0.85em;transition:opacity .3s';
            document.body.appendChild(t);
        }
        t.textContent = msg;
        t.style.opacity = '1';
        clearTimeout(t._timer);
        t._timer = setTimeout(() => t.style.opacity = '0', 2000);
    }

    // UI helpers
    function updateStatus(message, type) {
        const statusEl = document.getElementById('connectionStatus');
        const messageEl = document.getElementById('statusMessage');
        
        statusEl.className = `ms-3 status-${type}`;
        statusEl.textContent = `● ${message}`;
        
        if (messageEl) {
            messageEl.textContent = message;
        }
    }

    function updateFPS() {
        const now = Date.now();
        if (now - lastFpsUpdate >= 1000) {
            fps = frameCount;
            frameCount = 0;
            lastFpsUpdate = now;
            
            document.getElementById('fpsCounter').textContent = fps;
        }
        document.getElementById('frameCounter').textContent = frameCount;
    }

    // Button actions
    document.getElementById('btnRequestControl').addEventListener('click', async () => {
        if (connection) {
            await connection.invoke("RequestControl", sessionId, "web-viewer");
            updateStatus("Изчакване одобрение от host...", "connecting");
        }
    });

    document.getElementById('btnDisconnect').addEventListener('click', async () => {
        if (connection) {
            await connection.invoke("DisconnectSession", sessionId);
            window.location.href = '/RemoteDesktop';
        }
    });

    // Start connection
    connectToRemoteDesktop();
</script>
}
