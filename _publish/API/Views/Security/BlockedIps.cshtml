@model List<ADS.WindowsAuth.Core.Data.Entities.BlockedIpEntity>
@{
    ViewData["Title"] = "Блокирани IP адреси";
    var activeBlocked = Model.Where(b => b.IsBlocked).ToList();
    var unblocked = Model.Where(b => !b.IsBlocked).OrderByDescending(b => b.UnblockedAt).ToList();
}

<div class="container-fluid px-4 py-3">
    <div class="d-flex align-items-center mb-4 gap-2">
        <i class="bi bi-shield-x fs-3 text-danger"></i>
        <div>
            <h2 class="mb-0">Блокирани IP адреси</h2>
            <small class="text-muted">Управление на IP адреси блокирани от брутфорс защитата</small>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Статистика -->
    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card border-danger">
                <div class="card-body d-flex align-items-center gap-3">
                    <i class="bi bi-shield-x fs-1 text-danger"></i>
                    <div>
                        <div class="fs-2 fw-bold text-danger">@activeBlocked.Count</div>
                        <div class="text-muted small">Активно блокирани</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-success">
                <div class="card-body d-flex align-items-center gap-3">
                    <i class="bi bi-shield-check fs-1 text-success"></i>
                    <div>
                        <div class="fs-2 fw-bold text-success">@unblocked.Count</div>
                        <div class="text-muted small">Деблокирани</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-secondary">
                <div class="card-body d-flex align-items-center gap-3">
                    <i class="bi bi-list-ul fs-1 text-secondary"></i>
                    <div>
                        <div class="fs-2 fw-bold">@Model.Count</div>
                        <div class="text-muted small">Общо записи</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Активно блокирани -->
    <div class="card mb-4">
        <div class="card-header d-flex align-items-center gap-2 bg-danger text-white">
            <i class="bi bi-shield-x"></i>
            <strong>Активно блокирани IP адреси (@activeBlocked.Count)</strong>
        </div>
        <div class="card-body p-0">
            @if (!activeBlocked.Any())
            {
                <div class="text-center text-muted py-4">
                    <i class="bi bi-shield-check fs-1"></i>
                    <p class="mt-2">Няма блокирани IP адреси.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>IP Адрес</th>
                                <th>Неуспешни опити</th>
                                <th>Блокиран в</th>
                                <th>Последен опит</th>
                                <th>Действие</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ip in activeBlocked.OrderByDescending(b => b.BlockedAt))
                            {
                                <tr>
                                    <td>
                                        <span class="font-monospace fw-bold text-danger">
                                            <i class="bi bi-geo-alt me-1"></i>@ip.IpAddress
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-danger">@ip.FailedAttempts опита</span>
                                    </td>
                                    <td>
                                        <span title="@ip.BlockedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")">
                                            @ip.BlockedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                        </span>
                                    </td>
                                    <td>
                                        <span title="@ip.LastAttemptAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")">
                                            @ip.LastAttemptAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                        </span>
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-success"
                                                data-bs-toggle="modal" data-bs-target="#unblockModal"
                                                data-ip="@ip.IpAddress">
                                            <i class="bi bi-unlock me-1"></i>Деблокирай
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- История на деблокираните -->
    @if (unblocked.Any())
    {
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2 bg-secondary text-white"
                 style="cursor:pointer" data-bs-toggle="collapse" data-bs-target="#historyCollapse">
                <i class="bi bi-clock-history"></i>
                <strong>История на деблокираните (@unblocked.Count)</strong>
                <i class="bi bi-chevron-down ms-auto"></i>
            </div>
            <div class="collapse" id="historyCollapse">
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>IP Адрес</th>
                                <th>Блокиран в</th>
                                <th>Неуспешни опити</th>
                                <th>Деблокиран в</th>
                                <th>Деблокиран от</th>
                                <th>Причина</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ip in unblocked)
                            {
                                <tr class="text-muted">
                                    <td class="font-monospace">@ip.IpAddress</td>
                                    <td>@ip.BlockedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                    <td><span class="badge bg-secondary">@ip.FailedAttempts</span></td>
                                    <td>@ip.UnblockedAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@(ip.UnblockedBy ?? "-")</td>
                                    <td>@(ip.UnblockReason ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal за деблокиране -->
<div class="modal fade" id="unblockModal" tabindex="-1" aria-labelledby="unblockModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="unblockModalLabel">
                    <i class="bi bi-unlock me-2"></i>Деблокиране на IP адрес
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/security/blocked-ips/unblock">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <p>Сигурни ли сте, че искате да деблокирате IP адрес:</p>
                    <p class="fs-5 fw-bold font-monospace text-danger" id="modalIpDisplay"></p>
                    <input type="hidden" name="ip" id="modalIpInput" />
                    <div class="mb-3">
                        <label for="reason" class="form-label">Причина за деблокиране (опционална)</label>
                        <input type="text" class="form-control" id="reason" name="reason"
                               placeholder="напр. Легитимен потребител, тест, ..." maxlength="500" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отказ</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-unlock me-1"></i>Деблокирай
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('unblockModal').addEventListener('show.bs.modal', function (event) {
        var btn = event.relatedTarget;
        var ip = btn.getAttribute('data-ip');
        document.getElementById('modalIpDisplay').textContent = ip;
        document.getElementById('modalIpInput').value = ip;
        document.getElementById('reason').value = '';
    });
</script>
}
