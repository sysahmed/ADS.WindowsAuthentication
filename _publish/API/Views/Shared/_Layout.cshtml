<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#667eea" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="ADS Auth" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <title>@ViewData["Title"] - ADS Windows Authentication</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/style.css" rel="stylesheet" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <nav class="navbar navbar-expand-lg navbar-dark mb-3" style="background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); padding: 0.5rem 1rem;">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" href="/Home">🔐 ADS Auth</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navMenu">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link" href="/Home"><i class="bi bi-house"></i> Начало</a></li>
                        <li class="nav-item"><a class="nav-link" href="/monitor"><i class="bi bi-pc-display"></i> Монитор</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Account/Profile"><i class="bi bi-person"></i> Профил</a></li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link" href="/Account/Users"><i class="bi bi-people"></i> Потребители</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Account/Roles"><i class="bi bi-shield-lock"></i> Роли</a></li>
                            <li class="nav-item"><a class="nav-link" href="/security/blocked-ips"><i class="bi bi-shield-x"></i> Блокирани IP</a></li>
                        }
                    </ul>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-flex">
                        @Html.AntiForgeryToken()
                        <span class="navbar-text text-white me-2">@User.Identity?.Name</span>
                        <button type="submit" class="btn btn-outline-light btn-sm">Изход</button>
                    </form>
                </div>
            </div>
        </nav>
    }
    @RenderBody()
    <script src="/js/app.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- PWA Service Worker Registration -->
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then((registration) => {
                        console.log('Service Worker регистриран:', registration.scope);
                    })
                    .catch((error) => {
                        console.log('Service Worker регистрация неуспешна:', error);
                    });
            });
        }

        // PWA Install Prompt
        let deferredPrompt;
        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            // Може да покажете бутон за инсталация
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

