@{
    ViewData["Title"] = "Биометричен Вход";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="glass-card scale-in text-center p-4">
                <div style="font-size: 4rem; margin-bottom: 1rem;">🔐</div>
                <h2 class="mb-1">Биометричен Вход</h2>
                <p class="text-muted mb-4">Вход с Windows Hello, Touch ID или YubiKey</p>

                <div id="errorAlert" class="alert alert-danger d-none" role="alert"></div>
                <div id="successAlert" class="alert alert-success d-none" role="alert"></div>

                <div class="mb-3 text-start">
                    <label for="username" class="form-label">Потребителско Име</label>
                    <input type="text" class="form-control" id="username"
                           placeholder="domain\\username или username"
                           autocomplete="username webauthn">
                </div>

                <button class="btn btn-primary btn-lg w-100 mb-3" id="btnLogin" onclick="startLogin()">
                    <span id="loginBtnContent">
                        🔓 Вход с Биометрия
                    </span>
                </button>

                <div class="d-flex justify-content-between mt-3">
                    <a href="/WebAuthn/Register" class="btn btn-outline-secondary btn-sm">
                        📱 Регистрирай устройство
                    </a>
                    <a href="/auth" class="btn btn-outline-secondary btn-sm">
                        🔑 Вход с Парола
                    </a>
                </div>

                <div class="mt-4 p-3 rounded" style="background: rgba(255,255,255,0.05); font-size: 0.85em;">
                    <div class="text-muted">
                        <strong>🛡️ Сигурност:</strong> Паролата никога не се изпраща.
                        Вашата биометрична информация остава само на устройството.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
async function startLogin() {
    const username = document.getElementById('username').value.trim();
    const btn = document.getElementById('btnLogin');
    const btnContent = document.getElementById('loginBtnContent');

    showError('');
    showSuccess('');

    if (!username) {
        showError('Моля, въведете потребителско име');
        return;
    }

    try {
        btn.disabled = true;
        btnContent.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Изчакване на биометрия...';

        // Стъпка 1: Вземаме challenge от сървъра
        const beginResp = await fetch('/api/webauthn/authenticate/begin', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username })
        });

        if (!beginResp.ok) {
            const err = await beginResp.json();
            throw new Error(err.error || 'Грешка при инициализация');
        }

        const options = await beginResp.json();

        // Стъпка 2: WebAuthn assertion
        const credentialRequestOptions = {
            publicKey: {
                challenge: base64UrlToBuffer(options.challenge),
                rpId: options.rpId,
                allowCredentials: options.allowCredentials.map(c => ({
                    type: c.type,
                    id: base64UrlToBuffer(c.id)
                })),
                userVerification: options.userVerification,
                timeout: options.timeout
            }
        };

        const assertion = await navigator.credentials.get(credentialRequestOptions);

        // Стъпка 3: Изпращаме assertion за верификация
        const completeResp = await fetch('/api/webauthn/authenticate/complete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                challengeKey: options.challengeKey,
                credentialId: bufferToBase64Url(assertion.rawId),
                authenticatorData: bufferToBase64Url(assertion.response.authenticatorData),
                clientDataJson: bufferToBase64Url(assertion.response.clientDataJSON),
                signature: bufferToBase64Url(assertion.response.signature)
            })
        });

        if (!completeResp.ok) {
            const err = await completeResp.json();
            throw new Error(err.error || 'Аутентикацията неуспешна');
        }

        const result = await completeResp.json();
        showSuccess(`✅ Добре дошъл, ${result.username}!`);

        // Съхраняваме JWT токена
        if (result.token) {
            sessionStorage.setItem('ads_jwt_token', result.token);
            localStorage.setItem('ads_jwt_token', result.token);
        }

        // Пренасочваме след 1 секунда
        setTimeout(() => {
            window.location.href = result.redirectUrl || '/';
        }, 1000);

    } catch (error) {
        if (error.name === 'NotAllowedError') {
            showError('Биометричната верификация беше отказана или отменена.');
        } else if (error.name === 'NotSupportedError') {
            showError('Вашето устройство не поддържа WebAuthn/FIDO2.');
        } else {
            showError(`Грешка: ${error.message}`);
        }
        btn.disabled = false;
        btnContent.innerHTML = '🔓 Вход с Биометрия';
    }
}

function showError(msg) {
    const el = document.getElementById('errorAlert');
    el.textContent = msg;
    el.classList.toggle('d-none', !msg);
}

function showSuccess(msg) {
    const el = document.getElementById('successAlert');
    el.textContent = msg;
    el.classList.toggle('d-none', !msg);
}

function base64UrlToBuffer(base64url) {
    const base64 = base64url.replace(/-/g, '+').replace(/_/g, '/');
    const binStr = atob(base64);
    const buf = new Uint8Array(binStr.length);
    for (let i = 0; i < binStr.length; i++) buf[i] = binStr.charCodeAt(i);
    return buf.buffer;
}

function bufferToBase64Url(buffer) {
    const bytes = new Uint8Array(buffer);
    let str = '';
    for (const b of bytes) str += String.fromCharCode(b);
    return btoa(str).replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
}
</script>
}
